{
  "contract_version": 1,
  "current_schema_version": "1.0",
  "outcome_vocabulary": [
    "read_only_open",
    "degraded_fallback",
    "proposed_update",
    "accepted_commit",
    "rejected_commit",
    "conflict",
    "migration",
    "restore"
  ],
  "outcome_semantics": {
    "read_only_open": {
      "mutates_disk": false,
      "meaning": "Open and project a usable view without creating, moving, repairing, or rewriting a document."
    },
    "degraded_fallback": {
      "mutates_disk": false,
      "meaning": "Return a usable but untrusted view with diagnostics and risk-sensitive fallbacks."
    },
    "proposed_update": {
      "mutates_disk": false,
      "meaning": "Validate all requested fields as one unit and name only accepted requested canonical fields."
    },
    "accepted_commit": {
      "mutates_disk": true,
      "meaning": "With caller consent and a matching revision, atomically patch only requested canonical nodes."
    },
    "rejected_commit": {
      "mutates_disk": false,
      "meaning": "Reject an invalid or disallowed update as one unit without a partial write."
    },
    "conflict": {
      "mutates_disk": false,
      "meaning": "Refuse a stale revision and leave the externally changed document untouched."
    },
    "migration": {
      "ordinary_open_mutates_disk": false,
      "approved_apply_mutates_disk": true,
      "meaning": "Apply an explicit reversible shape, version, or location transition only after caller approval."
    },
    "restore": {
      "mutates_disk": true,
      "meaning": "Explicitly republish a verified pre-migration backup through conflict-safe atomic persistence."
    }
  },
  "canonical_defaults": {
    "source": "business-logic/classic-user-settings-core/src/default_settings.rs#MIRROR_SETTINGS",
    "generated_mirror": "CLASSIC Data/databases/CLASSIC Main.yaml#CLASSIC_Info.default_settings",
    "compatibility_only_fields": [
