// ReportViewer - Block-based markdown renderer with Copy All button
import { VerticalBox, HorizontalBox, Button, ScrollView } from "std-widgets.slint";
import { MarkdownBlock } from "types.slint";

export component ReportViewer inherits VerticalBox {
    // Raw markdown string for Copy All (preserved for backward compatibility)
    in-out property <string> content;
    // Parsed block model for rendering
    in property <[MarkdownBlock]> blocks;

    callback copy-all();

    spacing: 8px;

    // Toolbar with Copy All button
    HorizontalBox {
        height: 32px;

        // Flexible spacer pushes button to right
        Rectangle {
            horizontal-stretch: 1;
        }

        Button {
            text: "Copy All";
            clicked => {
                root.copy-all();
            }
        }
    }

    // Markdown content renderer
    ScrollView {
        vertical-stretch: 1;

        VerticalLayout {
            spacing: 4px;
            padding: 8px;

            for block in root.blocks: VerticalLayout {
                // Heading (block-type == 1)
                if block.block-type == 1: Text {
                    text: block.text;
                    font-size: block.heading-level == 1 ? 22px
                             : block.heading-level == 2 ? 18px
                             : 15px;
                    font-weight: 700;
                    wrap: word-wrap;
                }

                // Paragraph (block-type == 0)
                if block.block-type == 0: Text {
                    text: block.text;
                    font-size: 13px;
                    font-weight: block.is-bold ? 700 : 400;
                    font-italic: block.is-italic;
                    wrap: word-wrap;
                }

                // Code block (block-type == 2)
                if block.block-type == 2: Rectangle {
                    background: #2a2a2e;
                    border-radius: 4px;

                    VerticalLayout {
                        padding: 8px;
                        Text {
                            text: block.text;
                            font-family: "Consolas";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }

                // Horizontal rule (block-type == 3)
                if block.block-type == 3: Rectangle {
                    height: 1px;
                    background: #555555;
                }

                // List item (block-type == 4)
                if block.block-type == 4: HorizontalLayout {
                    spacing: 6px;

                    // Indent spacer
                    Rectangle {
                        width: block.indent-level * 16px;
                    }

                    Text {
                        text: block.bullet-marker;
                        font-size: 13px;
                        width: 16px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: block.text;
                        font-size: 13px;
                        font-weight: block.is-bold ? 700 : 400;
                        font-italic: block.is-italic;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }

                // Blockquote (block-type == 5)
                if block.block-type == 5: HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 3px;
                        background: #555555;
                        border-radius: 1px;
                    }
                    Text {
                        text: block.text;
                        font-size: 13px;
                        font-weight: block.is-bold ? 700 : 400;
                        font-italic: true;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                    }
                }
            }
        }
    }
}
