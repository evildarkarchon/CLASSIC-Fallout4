// Shared type definitions for CLASSIC GUI widgets

/// Intermediate representation of a rendered markdown block.
/// block-type: 0=paragraph, 1=heading, 2=code-block, 3=rule, 4=list-item, 5=blockquote
export struct MarkdownBlock {
    block-type: int,
    text: string,
    heading-level: int,
    is-bold: bool,
    is-italic: bool,
    indent-level: int,
    bullet-marker: string,
}
