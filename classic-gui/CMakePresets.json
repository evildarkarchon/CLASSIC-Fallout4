{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (vcpkg Qt6 + Ninja)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
                }
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (vcpkg Qt6 + Ninja)",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "system-fallback",
            "displayName": "System Qt fallback (vcpkg-first + Ninja)",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build-system-fallback",
            "cacheVariables": {
                "CLASSIC_GUI_ALLOW_SYSTEM_QT_FALLBACK": "ON"
            }
        },
        {
            "name": "system-fallback-debug",
            "displayName": "System Qt fallback Debug (vcpkg-first + Ninja)",
            "inherits": "debug",
            "binaryDir": "${sourceDir}/build-system-fallback-debug",
            "cacheVariables": {
                "CLASSIC_GUI_ALLOW_SYSTEM_QT_FALLBACK": "ON"
            }
        },
        {
            "name": "ci",
            "displayName": "CI (vcpkg Qt6 + Ninja)",
            "inherits": "default",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ci-debug",
            "displayName": "CI Debug (vcpkg Qt6 + Ninja)",
            "inherits": "ci",
            "binaryDir": "${sourceDir}/build-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "debug",
            "configurePreset": "debug"
        },
        {
            "name": "system-fallback",
            "configurePreset": "system-fallback"
        },
        {
            "name": "system-fallback-debug",
            "configurePreset": "system-fallback-debug"
        },
        {
            "name": "ci",
            "configurePreset": "ci"
        },
        {
            "name": "ci-debug",
            "configurePreset": "ci-debug"
        }
    ]
}
