// SettingsPaths - Paths settings sub-tab for the Settings tab
// Contains: INI Folder, Mods Folder with validation error display

import { Button, LineEdit, HorizontalBox, VerticalBox } from "std-widgets.slint";

component SettingsPathInput inherits VerticalBox {
    in-out property <string> path;
    in-out property <string> label;
    in-out property <string> error-message: "";
    in-out property <bool> has-error: false;
    callback browse-clicked();
    callback path-accepted(string);

    spacing: 4px;

    HorizontalBox {
        spacing: 8px;
        max-height: 40px;
        Text {
            text: root.label;
            min-width: 140px;
            vertical-alignment: center;
        }
        LineEdit {
            text <=> root.path;
            horizontal-stretch: 1;
            placeholder-text: "Select folder...";
            accepted(text) => {
                root.path-accepted(text);
            }
            // Save on focus loss
            changed has-focus => {
                if (!self.has-focus) {
                    root.path-accepted(self.text);
                }
            }
        }
        Button {
            text: "Browse...";
            clicked => { root.browse-clicked(); }
        }
    }
    if root.has-error : Text {
        text: root.error-message;
        color: #ff6b6b;
        font-size: 11px;
    }
}

component DatabaseRow inherits HorizontalBox {
    in property <string> name;
    in property <int> index;
    callback remove-clicked(int);
    spacing: 8px;
    height: 32px;

    Text {
        text: root.name;
        vertical-alignment: center;
        horizontal-stretch: 1;
        overflow: elide;
    }
    Button {
        text: "\u{2715}";
        clicked => { root.remove-clicked(root.index); }
        max-width: 32px;
    }
}

export component SettingsPaths inherits VerticalBox {
    // INI Folder
    in-out property <string> ini-path: "";
    in-out property <string> ini-error: "";
    in-out property <bool> ini-has-error: false;

    // Mods Folder
    in-out property <string> mods-path: "";
    in-out property <string> mods-error: "";
    in-out property <bool> mods-has-error: false;

    // Custom Scan Folder
    in-out property <string> scan-custom-path: "";
    in-out property <string> scan-custom-error: "";
    in-out property <bool> scan-custom-has-error: false;

    // Database list
    in property <[string]> database-list;

    // Browse callbacks
    callback browse-ini();
    callback browse-mods();
    callback browse-scan-custom();

    // Path accepted callbacks (Enter key or focus loss)
    callback ini-path-accepted(string);
    callback mods-path-accepted(string);
    callback scan-custom-path-accepted(string);

    // Database list callbacks
    callback database-add-clicked();
    callback database-remove-clicked(int);

    padding: 16px;
    spacing: 16px;

    SettingsPathInput {
        label: "INI Folder:";
        path <=> root.ini-path;
        error-message <=> root.ini-error;
        has-error <=> root.ini-has-error;
        browse-clicked => { root.browse-ini(); }
        path-accepted(text) => { root.ini-path-accepted(text); }
    }

    SettingsPathInput {
        label: "Mods Folder:";
        path <=> root.mods-path;
        error-message <=> root.mods-error;
        has-error <=> root.mods-has-error;
        browse-clicked => { root.browse-mods(); }
        path-accepted(text) => { root.mods-path-accepted(text); }
    }

    SettingsPathInput {
        label: "Custom Scan Folder:";
        path <=> root.scan-custom-path;
        error-message <=> root.scan-custom-error;
        has-error <=> root.scan-custom-has-error;
        browse-clicked => { root.browse-scan-custom(); }
        path-accepted(text) => { root.scan-custom-path-accepted(text); }
    }

    Text {
        text: "FormID Databases";
        font-weight: 700;
    }
    Text {
        text: "Additional databases loaded for FormID lookups during scanning.";
        color: #888888;
        font-size: 11px;
        wrap: word-wrap;
    }
    for db[index] in root.database-list : DatabaseRow {
        name: db;
        index: index;
        remove-clicked(i) => { root.database-remove-clicked(i); }
    }
    Button {
        text: "Add...";
        max-width: 100px;
        clicked => { root.database-add-clicked(); }
    }

    // Spacer to push content to top
    Rectangle {
        vertical-stretch: 1;
    }
}
