// CLASSIC GUI - Main Window
// Production UI with fluent-dark theme, 3-tab layout, and styled controls

import { Button, ProgressIndicator, TabWidget, VerticalBox, HorizontalBox, LineEdit, GroupBox } from "std-widgets.slint";
import { PathInput } from "widgets/path_input.slint";
import { ReportList, ReportEntry } from "widgets/report_list.slint";
import { ReportViewer } from "widgets/report_viewer.slint";
import { Splitter } from "widgets/splitter.slint";
import { MarkdownBlock } from "widgets/types.slint";
import { SettingsGeneral } from "widgets/settings_general.slint";
import { SettingsScanning } from "widgets/settings_scanning.slint";
import { SettingsPaths } from "widgets/settings_paths.slint";
export { MarkdownBlock }

export component MainWindow inherits Window {
    // Window properties - production dimensions per CONTEXT.md
    title: "Crash Log Auto Scanner and Setup Integrity Checker v9.0.0";
    icon: @image-url("../assets/CLASSIC.ico");
    preferred-width: 800px;
    preferred-height: 600px;
    min-width: 640px;
    min-height: 480px;

    // Properties accessible from Rust (use kebab-case, Slint converts to snake_case for Rust)
    in-out property <float> scan-progress: 0;
    in-out property <string> scan-status: "Ready";
    in-out property <bool> scan-in-progress: false;

    // Path input properties
    in-out property <string> crash-log-path: "";
    in-out property <string> game-path: "";

    // Tab tracking for state persistence (Plan 02)
    in-out property <int> active-tab-index: 0;

    // Results tab properties
    in-out property <[ReportEntry]> report-list-model;
    in-out property <string> report-content: "";
    in-out property <[MarkdownBlock]> report-blocks;
    in-out property <bool> has-reports: false;
    in-out property <int> selected-report-index: -1;
    in-out property <bool> report-sort-ascending: false;
    in-out property <length> list-panel-width: 200px;

    // Settings tab properties - General
    in-out property <int> setting-game-version-index: 0;
    in-out property <string> setting-auto-detected-hint: "";
    in-out property <bool> setting-update-check: true;
    in-out property <bool> setting-fcx-mode: false;
    in-out property <bool> setting-generate-stats: false;

    // Settings tab properties - Scanning
    in-out property <bool> setting-simplify-logs: false;
    in-out property <bool> setting-show-formid-values: false;
    in-out property <bool> setting-move-unsolved-logs: false;
    in-out property <bool> setting-auto-switch-after-scan: true;

    // Settings tab properties - Paths
    in-out property <string> setting-ini-path: "";
    in-out property <string> setting-ini-error: "";
    in-out property <bool> setting-ini-has-error: false;
    in-out property <string> setting-mods-path: "";
    in-out property <string> setting-mods-error: "";
    in-out property <bool> setting-mods-has-error: false;

    // Settings tab properties - Paths (custom scan folder)
    in-out property <string> setting-scan-custom-path: "";
    in-out property <string> setting-scan-custom-error: "";
    in-out property <bool> setting-scan-custom-has-error: false;

    // Settings tab properties - Paths (database list)
    in-out property <[string]> setting-database-list;

    // Settings tab - Reset to Defaults
    property <bool> reset-confirm-visible: false;

    // Callbacks invoked from UI
    callback start-scan-logs();
    callback start-scan-game();
    callback cancel-scan();
    callback browse-crash-logs();
    callback browse-game-folder();
    callback tab-changed(int);

    // Results tab callbacks
    callback report-selected(int);
    callback report-search-changed(string);
    callback report-sort-toggled();
    callback report-copy-all();

    // Settings tab callbacks - General
    callback setting-game-version-changed(int);
    callback setting-update-check-changed(bool);
    callback setting-fcx-mode-changed(bool);
    callback setting-generate-stats-changed(bool);

    // Settings tab callbacks - Scanning
    callback setting-simplify-logs-changed(bool);
    callback setting-show-formid-values-changed(bool);
    callback setting-move-unsolved-logs-changed(bool);
    callback setting-auto-switch-after-scan-changed(bool);

    // Settings tab callbacks - Paths
    callback setting-browse-ini();
    callback setting-browse-mods();
    callback setting-ini-path-accepted(string);
    callback setting-mods-path-accepted(string);

    // Settings tab callbacks - Paths (custom scan folder)
    callback setting-browse-scan-custom();
    callback setting-scan-custom-path-accepted(string);

    // Settings tab callbacks - Paths (database list)
    callback setting-database-add-clicked();
    callback setting-database-remove-clicked(int);

    // Settings tab callbacks - Reset
    callback setting-reset-to-defaults();

    VerticalBox {
        padding: 12px;
        spacing: 12px;

        TabWidget {
            current-index <=> root.active-tab-index;

            Tab {
                title: "Main Options";
                VerticalBox {
                    padding: 16px;
                    spacing: 12px;

                    // Folder paths section
                    GroupBox {
                        title: "Folder Paths";
                        VerticalBox {
                            spacing: 10px;
                            padding: 8px;

                            // Crash log folder
                            HorizontalBox {
                                spacing: 8px;
                                max-height: 40px;
                                Text {
                                    text: "Crash Logs:";
                                    vertical-alignment: center;
                                    min-width: 100px;
                                }
                                PathInput {
                                    path <=> root.crash-log-path;
                                    placeholder: "Select crash log folder...";
                                    enabled: !root.scan-in-progress;
                                    browse-clicked => { root.browse-crash-logs(); }
                                }
                            }

                            // Game folder
                            HorizontalBox {
                                spacing: 8px;
                                max-height: 40px;
                                Text {
                                    text: "Game Folder:";
                                    vertical-alignment: center;
                                    min-width: 100px;
                                }
                                PathInput {
                                    path <=> root.game-path;
                                    placeholder: "Select game folder...";
                                    enabled: !root.scan-in-progress;
                                    browse-clicked => { root.browse-game-folder(); }
                                }
                            }
                        }
                    }

                    // Flexible spacer to push buttons to bottom
                    Rectangle {
                        vertical-stretch: 1;
                    }

                    // Action buttons
                    HorizontalBox {
                        alignment: center;
                        spacing: 12px;

                        Button {
                            text: root.scan-in-progress ? "Cancel" : "Scan Crash Logs";
                            primary: !root.scan-in-progress;
                            enabled: true;
                            clicked => {
                                if (root.scan-in-progress) {
                                    root.cancel-scan();
                                } else {
                                    root.start-scan-logs();
                                }
                            }
                        }

                        Button {
                            text: root.scan-in-progress ? "Cancel" : "Scan Game Files";
                            enabled: !root.scan-in-progress;
                            clicked => {
                                if (root.scan-in-progress) {
                                    root.cancel-scan();
                                } else {
                                    root.start-scan-game();
                                }
                            }
                        }
                    }
                }
            }

            Tab {
                title: "Results";
                VerticalBox {
                    padding: 8px;
                    spacing: 0;

                    // Empty state: no scan results yet
                    if !root.has-reports : VerticalBox {
                        alignment: center;
                        vertical-stretch: 1;
                        spacing: 12px;

                        Text {
                            text: "No scan results";
                            font-size: 16px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Run a scan to see results here";
                            color: #888888;
                            horizontal-alignment: center;
                        }
                        HorizontalBox {
                            alignment: center;
                            Button {
                                text: "Scan Crash Logs";
                                primary: true;
                                clicked => {
                                    root.active-tab-index = 0;
                                }
                            }
                        }
                    }

                    // Master-detail layout: report list + splitter + viewer
                    if root.has-reports : HorizontalLayout {
                        vertical-stretch: 1;

                        ReportList {
                            width: clamp(150px, root.list-panel-width, 400px);
                            model <=> root.report-list-model;
                            selected-index <=> root.selected-report-index;
                            sort-ascending <=> root.report-sort-ascending;
                            report-selected(idx) => {
                                root.report-selected(idx);
                            }
                            search-changed(text) => {
                                root.report-search-changed(text);
                            }
                            sort-toggled => {
                                root.report-sort-toggled();
                            }
                        }

                        Splitter {
                            moved(delta) => {
                                root.list-panel-width = root.list-panel-width + delta;
                            }
                        }

                        ReportViewer {
                            horizontal-stretch: 1;
                            content <=> root.report-content;
                            blocks: root.report-blocks;
                            copy-all => {
                                root.report-copy-all();
                            }
                        }
                    }
                }
            }

            Tab {
                title: "Settings";
                VerticalBox {
                    padding: 8px;
                    spacing: 8px;

                    TabWidget {
                        vertical-stretch: 1;

                        Tab {
                            title: "General";
                            SettingsGeneral {
                                game-version-index <=> root.setting-game-version-index;
                                auto-detected-hint <=> root.setting-auto-detected-hint;
                                update-check <=> root.setting-update-check;
                                fcx-mode <=> root.setting-fcx-mode;
                                game-version-changed(idx) => { root.setting-game-version-changed(idx); }
                                update-check-changed(val) => { root.setting-update-check-changed(val); }
                                fcx-mode-changed(val) => { root.setting-fcx-mode-changed(val); }
                                generate-stats <=> root.setting-generate-stats;
                                generate-stats-changed(val) => { root.setting-generate-stats-changed(val); }
                            }
                        }

                        Tab {
                            title: "Scanning";
                            SettingsScanning {
                                simplify-logs <=> root.setting-simplify-logs;
                                show-formid-values <=> root.setting-show-formid-values;
                                move-unsolved-logs <=> root.setting-move-unsolved-logs;
                                auto-switch-after-scan <=> root.setting-auto-switch-after-scan;
                                simplify-logs-changed(val) => { root.setting-simplify-logs-changed(val); }
                                show-formid-values-changed(val) => { root.setting-show-formid-values-changed(val); }
                                move-unsolved-logs-changed(val) => { root.setting-move-unsolved-logs-changed(val); }
                                auto-switch-after-scan-changed(val) => { root.setting-auto-switch-after-scan-changed(val); }
                            }
                        }

                        Tab {
                            title: "Paths";
                            SettingsPaths {
                                ini-path <=> root.setting-ini-path;
                                ini-error <=> root.setting-ini-error;
                                ini-has-error <=> root.setting-ini-has-error;
                                mods-path <=> root.setting-mods-path;
                                mods-error <=> root.setting-mods-error;
                                mods-has-error <=> root.setting-mods-has-error;
                                browse-ini => { root.setting-browse-ini(); }
                                browse-mods => { root.setting-browse-mods(); }
                                ini-path-accepted(text) => { root.setting-ini-path-accepted(text); }
                                mods-path-accepted(text) => { root.setting-mods-path-accepted(text); }
                                scan-custom-path <=> root.setting-scan-custom-path;
                                scan-custom-error <=> root.setting-scan-custom-error;
                                scan-custom-has-error <=> root.setting-scan-custom-has-error;
                                browse-scan-custom => { root.setting-browse-scan-custom(); }
                                scan-custom-path-accepted(text) => { root.setting-scan-custom-path-accepted(text); }
                                database-list <=> root.setting-database-list;
                                database-add-clicked => { root.setting-database-add-clicked(); }
                                database-remove-clicked(index) => { root.setting-database-remove-clicked(index); }
                            }
                        }
                    }

                    // Reset to Defaults with inline confirmation
                    HorizontalBox {
                        alignment: center;
                        spacing: 8px;

                        if !root.reset-confirm-visible : Button {
                            text: "Reset to Defaults";
                            clicked => { root.reset-confirm-visible = true; }
                        }
                        if root.reset-confirm-visible : HorizontalBox {
                            spacing: 8px;
                            Text {
                                text: "Reset ALL settings to defaults?";
                                color: #ff6b6b;
                                vertical-alignment: center;
                            }
                            Button {
                                text: "Yes, Reset";
                                clicked => {
                                    root.setting-reset-to-defaults();
                                    root.reset-confirm-visible = false;
                                }
                            }
                            Button {
                                text: "Cancel";
                                clicked => { root.reset-confirm-visible = false; }
                            }
                        }
                    }
                }
            }
        }

        // Status bar - always visible at bottom (visible across all tabs)
        VerticalBox {
            spacing: 6px;
            ProgressIndicator {
                // Indeterminate when progress < 0 (discovery phase), determinate otherwise
                indeterminate: root.scan-progress < 0;
                progress: root.scan-progress >= 0 ? root.scan-progress / 100 : 0;
            }
            Text {
                text: root.scan-status;
                horizontal-alignment: center;
            }
        }
    }
}
