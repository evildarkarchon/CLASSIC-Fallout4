// CLASSIC GUI - Main Window
// Production UI with fluent-dark theme, 3-tab layout, and styled controls

import { Button, ProgressIndicator, TabWidget, VerticalBox, HorizontalBox, LineEdit, CheckBox, GroupBox } from "std-widgets.slint";
import { PathInput } from "widgets/path_input.slint";

export component MainWindow inherits Window {
    // Window properties - production dimensions per CONTEXT.md
    title: "Crash Log Auto Scanner and Setup Integrity Checker v9.0.0";
    icon: @image-url("../assets/CLASSIC.ico");
    preferred-width: 800px;
    preferred-height: 600px;
    min-width: 640px;
    min-height: 480px;

    // Properties accessible from Rust (use kebab-case, Slint converts to snake_case for Rust)
    in-out property <float> scan-progress: 0;
    in-out property <string> scan-status: "Ready";
    in-out property <bool> scan-in-progress: false;

    // Path input properties
    in-out property <string> crash-log-path: "";
    in-out property <string> game-path: "";

    // Tab tracking for state persistence (Plan 02)
    in-out property <int> active-tab-index: 0;

    // Scan option properties
    in-out property <bool> option-scan-logs: true;
    in-out property <bool> option-scan-game: false;
    in-out property <bool> option-generate-stats: false;

    // Callbacks invoked from UI
    callback start-scan();
    callback cancel-scan();
    callback browse-crash-logs();
    callback browse-game-folder();
    callback tab-changed(int);

    VerticalBox {
        padding: 12px;
        spacing: 12px;

        TabWidget {
            current-index <=> root.active-tab-index;

            Tab {
                title: "Main Options";
                VerticalBox {
                    padding: 16px;
                    spacing: 12px;

                    // Folder paths section
                    GroupBox {
                        title: "Folder Paths";
                        VerticalBox {
                            spacing: 10px;
                            padding: 8px;

                            // Crash log folder
                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Crash Logs:";
                                    vertical-alignment: center;
                                    min-width: 100px;
                                }
                                PathInput {
                                    path <=> root.crash-log-path;
                                    placeholder: "Select crash log folder...";
                                    enabled: !root.scan-in-progress;
                                    browse-clicked => { root.browse-crash-logs(); }
                                }
                            }

                            // Game folder
                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Game Folder:";
                                    vertical-alignment: center;
                                    min-width: 100px;
                                }
                                PathInput {
                                    path <=> root.game-path;
                                    placeholder: "Select game folder...";
                                    enabled: !root.scan-in-progress;
                                    browse-clicked => { root.browse-game-folder(); }
                                }
                            }
                        }
                    }

                    // Scan options section
                    GroupBox {
                        title: "Scan Options";
                        VerticalBox {
                            spacing: 8px;
                            padding: 8px;
                            CheckBox {
                                text: "Scan crash logs";
                                checked <=> root.option-scan-logs;
                                enabled: !root.scan-in-progress;
                            }
                            CheckBox {
                                text: "Scan game files";
                                checked <=> root.option-scan-game;
                                enabled: !root.scan-in-progress;
                            }
                            CheckBox {
                                text: "Generate statistics";
                                checked <=> root.option-generate-stats;
                                enabled: !root.scan-in-progress;
                            }
                        }
                    }

                    // Flexible spacer to push button to bottom
                    Rectangle {
                        vertical-stretch: 1;
                    }

                    // Scan button centered at bottom
                    HorizontalBox {
                        alignment: center;
                        spacing: 12px;

                        Button {
                            text: root.scan-in-progress ? "Scanning..." : "Scan Crash Logs";
                            enabled: !root.scan-in-progress;
                            primary: true;
                            clicked => { root.start-scan(); }
                        }
                        Button {
                            text: "Cancel";
                            enabled: root.scan-in-progress;
                            clicked => { root.cancel-scan(); }
                        }
                    }
                }
            }

            Tab {
                title: "Results";
                VerticalBox {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: "Scan results will appear here";
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Results display will be implemented in Phase 22";
                        color: #888888;
                        horizontal-alignment: center;
                    }
                }
            }

            Tab {
                title: "Settings";
                VerticalBox {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: "Application Settings";
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Settings will be implemented in Phase 24";
                        color: #888888;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // Progress area - always visible at bottom
        VerticalBox {
            spacing: 6px;
            ProgressIndicator {
                progress: root.scan-progress / 100;
            }
            Text {
                text: root.scan-status;
                horizontal-alignment: center;
            }
        }
    }
}
