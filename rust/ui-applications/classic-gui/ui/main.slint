// CLASSIC GUI - Main Window
// Production UI with fluent-dark theme, 3-tab layout, and styled controls

import { Button, ProgressIndicator, TabWidget, VerticalBox, HorizontalBox, LineEdit, CheckBox, GroupBox } from "std-widgets.slint";
import { PathInput } from "widgets/path_input.slint";
import { ReportList, ReportEntry } from "widgets/report_list.slint";
import { ReportViewer } from "widgets/report_viewer.slint";
import { Splitter } from "widgets/splitter.slint";

export component MainWindow inherits Window {
    // Window properties - production dimensions per CONTEXT.md
    title: "Crash Log Auto Scanner and Setup Integrity Checker v9.0.0";
    icon: @image-url("../assets/CLASSIC.ico");
    preferred-width: 800px;
    preferred-height: 600px;
    min-width: 640px;
    min-height: 480px;

    // Properties accessible from Rust (use kebab-case, Slint converts to snake_case for Rust)
    in-out property <float> scan-progress: 0;
    in-out property <string> scan-status: "Ready";
    in-out property <bool> scan-in-progress: false;

    // Path input properties
    in-out property <string> crash-log-path: "";
    in-out property <string> game-path: "";

    // Tab tracking for state persistence (Plan 02)
    in-out property <int> active-tab-index: 0;

    // Scan option properties
    in-out property <bool> option-scan-logs: true;
    in-out property <bool> option-scan-game: false;
    in-out property <bool> option-generate-stats: false;

    // Results tab properties
    in-out property <[ReportEntry]> report-list-model;
    in-out property <string> report-content: "";
    in-out property <bool> has-reports: false;
    in-out property <int> selected-report-index: -1;
    in-out property <bool> report-sort-ascending: false;
    in-out property <length> list-panel-width: 200px;

    // Callbacks invoked from UI
    callback start-scan();
    callback cancel-scan();
    callback browse-crash-logs();
    callback browse-game-folder();
    callback tab-changed(int);

    // Results tab callbacks
    callback report-selected(int);
    callback report-search-changed(string);
    callback report-sort-toggled();
    callback report-copy-all();

    VerticalBox {
        padding: 12px;
        spacing: 12px;

        TabWidget {
            current-index <=> root.active-tab-index;

            Tab {
                title: "Main Options";
                VerticalBox {
                    padding: 16px;
                    spacing: 12px;

                    // Folder paths section
                    GroupBox {
                        title: "Folder Paths";
                        VerticalBox {
                            spacing: 10px;
                            padding: 8px;

                            // Crash log folder
                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Crash Logs:";
                                    vertical-alignment: center;
                                    min-width: 100px;
                                }
                                PathInput {
                                    path <=> root.crash-log-path;
                                    placeholder: "Select crash log folder...";
                                    enabled: !root.scan-in-progress;
                                    browse-clicked => { root.browse-crash-logs(); }
                                }
                            }

                            // Game folder
                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "Game Folder:";
                                    vertical-alignment: center;
                                    min-width: 100px;
                                }
                                PathInput {
                                    path <=> root.game-path;
                                    placeholder: "Select game folder...";
                                    enabled: !root.scan-in-progress;
                                    browse-clicked => { root.browse-game-folder(); }
                                }
                            }
                        }
                    }

                    // Scan options section
                    GroupBox {
                        title: "Scan Options";
                        VerticalBox {
                            spacing: 8px;
                            padding: 8px;
                            CheckBox {
                                text: "Scan crash logs";
                                checked <=> root.option-scan-logs;
                                enabled: !root.scan-in-progress;
                            }
                            CheckBox {
                                text: "Scan game files";
                                checked <=> root.option-scan-game;
                                enabled: !root.scan-in-progress;
                            }
                            CheckBox {
                                text: "Generate statistics";
                                checked <=> root.option-generate-stats;
                                enabled: !root.scan-in-progress;
                            }
                        }
                    }

                    // Flexible spacer to push button to bottom
                    Rectangle {
                        vertical-stretch: 1;
                    }

                    // Morphing Scan/Cancel button - single button, dual purpose
                    HorizontalBox {
                        alignment: center;

                        Button {
                            text: root.scan-in-progress ? "Cancel" : "Scan Crash Logs";
                            primary: !root.scan-in-progress;
                            clicked => {
                                if (root.scan-in-progress) {
                                    root.cancel-scan();
                                } else {
                                    root.start-scan();
                                }
                            }
                        }
                    }
                }
            }

            Tab {
                title: "Results";
                VerticalBox {
                    padding: 8px;
                    spacing: 0;

                    // Empty state: no scan results yet
                    if !root.has-reports : VerticalBox {
                        alignment: center;
                        vertical-stretch: 1;
                        spacing: 12px;

                        Text {
                            text: "No scan results";
                            font-size: 16px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Run a scan to see results here";
                            color: #888888;
                            horizontal-alignment: center;
                        }
                        HorizontalBox {
                            alignment: center;
                            Button {
                                text: "Scan Crash Logs";
                                primary: true;
                                clicked => {
                                    root.active-tab-index = 0;
                                }
                            }
                        }
                    }

                    // Master-detail layout: report list + splitter + viewer
                    if root.has-reports : HorizontalLayout {
                        vertical-stretch: 1;

                        ReportList {
                            width: clamp(150px, root.list-panel-width, 400px);
                            model <=> root.report-list-model;
                            selected-index <=> root.selected-report-index;
                            sort-ascending <=> root.report-sort-ascending;
                            report-selected(idx) => {
                                root.report-selected(idx);
                            }
                            search-changed(text) => {
                                root.report-search-changed(text);
                            }
                            sort-toggled => {
                                root.report-sort-toggled();
                            }
                        }

                        Splitter {
                            moved(delta) => {
                                root.list-panel-width = root.list-panel-width + delta;
                            }
                        }

                        ReportViewer {
                            horizontal-stretch: 1;
                            content <=> root.report-content;
                            copy-all => {
                                root.report-copy-all();
                            }
                        }
                    }
                }
            }

            Tab {
                title: "Settings";
                VerticalBox {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: "Application Settings";
                        font-size: 14px;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "Settings will be implemented in Phase 24";
                        color: #888888;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // Status bar - always visible at bottom (visible across all tabs)
        VerticalBox {
            spacing: 6px;
            ProgressIndicator {
                // Indeterminate when progress < 0 (discovery phase), determinate otherwise
                indeterminate: root.scan-progress < 0;
                progress: root.scan-progress >= 0 ? root.scan-progress / 100 : 0;
            }
            Text {
                text: root.scan-status;
                horizontal-alignment: center;
            }
        }
    }
}
