import { FluentDark } from "styles/fluent_dark.slint";
import { FluentTabBar } from "components/fluent_tab_bar.slint";
import { MainTab } from "tabs/main_tab.slint";
import { BackupsTab } from "tabs/backups_tab.slint";
import { ArticlesTab } from "tabs/articles_tab.slint";
import { ResultsTab } from "tabs/results_tab.slint";
import { ReportData } from "components/report_list.slint";
import { MarkdownMetadata } from "components/markdown_viewer.slint";

// Dialog components
import { SettingsDialog } from "dialogs/settings_dialog.slint";
import { AboutDialog } from "dialogs/about_dialog.slint";
import { UpdateDialog } from "dialogs/update_dialog.slint";
import { PapyrusDialog } from "dialogs/papyrus_dialog.slint";
import { ConfirmationDialog } from "components/confirmation_dialog.slint";
import { HelpDialog, RelatedTopicData } from "dialogs/help_dialog.slint";
import { PastebinDialog } from "dialogs/pastebin_dialog.slint";

// MainWindow - Primary application window with Fluent Design dark theme
export component MainWindow inherits Window {
    // Properties - version is injected from Rust code
    in property <string> app-version;

    // Tab control
    in-out property <int> current-tab: 0;

    // Main tab properties (exposed to Rust)
    in-out property <string> mods-folder-path: "";
    in-out property <string> scan-folder-path: "";
    in-out property <bool> scan-in-progress: false;
    in-out property <bool> papyrus-monitoring: false;

    // Backup tab properties (exposed to Rust)
    in-out property <bool> operation-in-progress: false;
    in-out property <bool> xse-backup-exists: false;
    in-out property <bool> reshade-backup-exists: false;
    in-out property <bool> vulkan-backup-exists: false;
    in-out property <bool> enb-backup-exists: false;

    // Results tab properties (exposed to Rust)
    in-out property <[ReportData]> reports-list: [];
    in-out property <int> selected-report-index: -1;
    in-out property <string> selected-report-path: "";
    in-out property <string> markdown-content: "";
    in-out property <MarkdownMetadata> markdown-metadata: {
        filename: "",
        file-size: "",
        display-date: ""
    };
    in-out property <int> zoom-level: 100;

    // Dialog properties (exposed to Rust)
    in-out property <bool> show-error-dialog: false;
    in-out property <string> error-title: "Error";
    in-out property <string> error-message: "";
    in-out property <string> error-details: "";  // Traceback/stack trace
    in-out property <bool> show-success-dialog: false;
    in-out property <string> success-title: "Success";
    in-out property <string> success-message: "";

    // Settings dialog properties
    in-out property <bool> show-settings-dialog: false;
    in-out property <bool> settings-fcx-mode: false;
    in-out property <bool> settings-show-formid-values: false;
    in-out property <bool> settings-stat-logging: false;
    in-out property <bool> settings-update-check: true;
    in-out property <bool> settings-vr-mode: false;
    in-out property <bool> settings-auto-switch-to-results: true;
    in-out property <bool> settings-move-unsolved-logs: false;
    in-out property <bool> settings-simplify-logs: false;
    in-out property <int> settings-auto-refresh-interval-s: 5; // New setting for file watcher (seconds)
    in-out property <string> settings-game-root: "";
    in-out property <string> settings-docs-root: "";
    in-out property <string> settings-ini-folder: "";
    in-out property <string> settings-mods-folder: "";
    in-out property <string> settings-scan-custom: "";

    // About dialog properties
    in-out property <bool> show-about-dialog: false;

    // Update dialog properties
    in-out property <bool> show-update-dialog: false;
    in-out property <bool> update-checking: false;
    in-out property <bool> update-available: false;
    in-out property <string> update-current-version: "";
    in-out property <string> update-latest-version: "";
    in-out property <string> update-release-notes: "";
    in-out property <string> update-error-message: "";
    in-out property <bool> update-dont-check-again: false;

    // Papyrus dialog properties
    in-out property <bool> show-papyrus-dialog: false;
    in-out property <string> papyrus-log-path: "";
    in-out property <int> papyrus-error-count: 0;
    in-out property <int> papyrus-warning-count: 0;
    in-out property <int> papyrus-info-count: 0;
    in-out property <int> papyrus-dumps-count: 0;   // NEW
    in-out property <int> papyrus-stacks-count: 0;  // NEW
    in-out property <string> papyrus-log-content: "";

    // Confirmation dialog properties
    in-out property <bool> show-confirmation-dialog: false;
    in-out property <string> confirmation-title: "Confirm Action";
    in-out property <string> confirmation-message: "Are you sure?";
    in-out property <string> confirmation-confirm-text: "Yes";
    in-out property <string> confirmation-cancel-text: "No";
    in-out property <bool> confirmation-is-danger: false;

    // Help dialog properties
    in-out property <bool> show-help-dialog: false;
    in-out property <string> help-title: "Help";
    in-out property <string> help-content: "";
    in-out property <[RelatedTopicData]> help-related-topics: [];

    // Pastebin dialog properties
    in-out property <bool> show-pastebin-dialog: false;
    in-out property <string> pastebin-url-input: "";
    in-out property <bool> pastebin-loading: false;

    // Window configuration
    title: "Crash Log Auto Scanner & Setup Integrity Checker | " + app-version;
    icon: @image-url("../assets/CLASSIC.ico");
    background: FluentDark.background;

    // Window size constraints
    min-width: 550px;
    min-height: 350px;
    preferred-width: 650px;
    preferred-height: 350px;

    // Callbacks for window lifecycle
    callback window-closed();
    callback tab-changed(int);

    // Main tab callbacks (forwarded to Rust)
    callback browse-mods-folder();
    callback browse-scan-folder();
    callback scan-crash-logs();
    callback scan-game-files();
    callback show-about();
    callback show-help();
    callback open-settings();
    callback open-crash-logs-folder();
    callback check-updates();
    callback toggle-papyrus();
    callback exit-app();
    callback copy-error-to-clipboard();

    // Backup tab callbacks (forwarded to Rust)
    callback backup-xse();
    callback restore-xse();
    callback remove-xse();
    callback backup-reshade();
    callback restore-reshade();
    callback remove-reshade();
    callback backup-vulkan();
    callback restore-vulkan();
    callback remove-vulkan();
    callback backup-enb();
    callback restore-enb();
    callback remove-enb();
    callback open-backups-folder();

    // Articles tab callbacks (forwarded to Rust)
    callback open-url(string);

    // Results tab callbacks (forwarded to Rust)
    callback refresh-reports();
    callback delete-report();
    callback open-reports-folder();
    callback report-selected(string);
    callback copy-to-clipboard();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();

    // Settings dialog callbacks
    callback settings-save();
    callback settings-cancel();
    callback settings-browse-path(string /* path-type */);

    // About dialog callbacks
    callback about-close();
    callback about-open-github();
    callback about-open-nexus();

    // Update dialog callbacks
    callback update-close();
    callback update-download();
    callback update-skip();

    // Papyrus dialog callbacks
    callback papyrus-close();
    callback papyrus-start-monitoring();
    callback papyrus-stop-monitoring();
    callback papyrus-clear-stats();
    callback papyrus-update-stats();  // NEW: Update stats from Rust

    // Confirmation dialog callbacks
    callback confirmation-confirmed();
    callback confirmation-cancelled();

    // Help dialog callbacks
    callback help-close();
    callback help-show-topic(/* category */ string, /* topic */ string);
    callback show-context-help();  // F1 key handler

    // Pastebin dialog callbacks
    callback pastebin-open();
    callback pastebin-cancel();

    // Keyboard event handling for F1 help
    FocusScope {
        key-pressed(event) => {
            if (event.text == Key.F1) {
                // F1 pressed - show context-sensitive help
                root.show-context-help();
                return accept;
            }
            return reject;
        }
    }

    // Main layout
    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Tab bar
        tab-bar := FluentTabBar {
            tabs: ["MAIN OPTIONS", "FILE BACKUP", "ARTICLES", "RESULTS"];
            current-tab <=> root.current-tab;
            tab-selected(index) => { root.tab-changed(index); }
        }

        // Tab content area
        Rectangle {
            background: FluentDark.background;

            // Tab content switcher
            if tab-bar.current-tab == 0: MainTab {
                mods-folder-path <=> root.mods-folder-path;
                scan-folder-path <=> root.scan-folder-path;
                scan-in-progress <=> root.scan-in-progress;
                papyrus-monitoring <=> root.papyrus-monitoring;

                // Dialog properties
                show-error-dialog <=> root.show-error-dialog;
                error-title <=> root.error-title;
                error-message <=> root.error-message;
                error-details <=> root.error-details;
                show-success-dialog <=> root.show-success-dialog;
                success-title <=> root.success-title;
                success-message <=> root.success-message;

                browse-mods-folder => { root.browse-mods-folder(); }
                browse-scan-folder => { root.browse-scan-folder(); }
                scan-crash-logs => { root.scan-crash-logs(); }
                scan-game-files => { root.scan-game-files(); }
                show-about => { root.show-about(); }
                show-help => { root.show-help(); }
                open-settings => { root.open-settings(); }
                open-crash-logs-folder => { root.open-crash-logs-folder(); }
                check-updates => { root.check-updates(); }
                toggle-papyrus => { root.toggle-papyrus(); }
                exit-app => { root.exit-app(); }
                copy-error-to-clipboard => { root.copy-error-to-clipboard(); }
            }
            if tab-bar.current-tab == 1: BackupsTab {
                operation-in-progress <=> root.operation-in-progress;
                xse-backup-exists <=> root.xse-backup-exists;
                reshade-backup-exists <=> root.reshade-backup-exists;
                vulkan-backup-exists <=> root.vulkan-backup-exists;
                enb-backup-exists <=> root.enb-backup-exists;

                // Forward callbacks to Rust
                backup-xse => { root.backup-xse(); }
                restore-xse => { root.restore-xse(); }
                remove-xse => { root.remove-xse(); }
                backup-reshade => { root.backup-reshade(); }
                restore-reshade => { root.restore-reshade(); }
                remove-reshade => { root.remove-reshade(); }
                backup-vulkan => { root.backup-vulkan(); }
                restore-vulkan => { root.restore-vulkan(); }
                remove-vulkan => { root.remove-vulkan(); }
                backup-enb => { root.backup-enb(); }
                restore-enb => { root.restore-enb(); }
                remove-enb => { root.remove-enb(); }
                open-backups-folder => { root.open-backups-folder(); }
            }
            if tab-bar.current-tab == 2: ArticlesTab {
                open-url(url) => { root.open-url(url); }
            }
            if tab-bar.current-tab == 3: ResultsTab {
                reports: root.reports-list;
                selected-report-index: root.selected-report-index;
                selected-report-path: root.selected-report-path;
                markdown-content <=> root.markdown-content;
                markdown-metadata <=> root.markdown-metadata;
                zoom-level <=> root.zoom-level;

                refresh-reports => { root.refresh-reports(); }
                delete-report => { root.delete-report(); }
                open-reports-folder => { root.open-reports-folder(); }
                report-selected(path) => { root.report-selected(path); }
                copy-to-clipboard => { root.copy-to-clipboard(); }
                zoom-in => { root.zoom-in(); }
                zoom-out => { root.zoom-out(); }
                zoom-reset => { root.zoom-reset(); }
            }
        }
    }

    // Dialog overlays (rendered on top of main content)

    // Settings Dialog
    SettingsDialog {
        show <=> root.show-settings-dialog;
        fcx-mode <=> root.settings-fcx-mode;
        show-formid-values <=> root.settings-show-formid-values;
        stat-logging <=> root.settings-stat-logging;
        update-check <=> root.settings-update-check;
        vr_mode <=> root.settings-vr-mode;
        auto-switch-to-results <=> root.settings-auto-switch-to-results;
        auto-refresh-interval-s <=> root.settings-auto-refresh-interval-s;
        move-unsolved-logs <=> root.settings-move-unsolved-logs;
        simplify-logs <=> root.settings-simplify-logs;
        game-root <=> root.settings-game-root;
        docs-root <=> root.settings-docs-root;
        ini-folder <=> root.settings-ini-folder;
        mods-folder <=> root.settings-mods-folder;
        scan-custom <=> root.settings-scan-custom;

        save-clicked => { root.settings-save(); }
        cancel-clicked => { root.settings-cancel(); }
        browse-path(path-type) => { root.settings-browse-path(path-type); }
    }

    // About Dialog
    AboutDialog {
        show <=> root.show-about-dialog;
        app-version: root.app-version;

        close-clicked => { root.about-close(); }
        open-github => { root.about-open-github(); }
        open-nexus => { root.about-open-nexus(); }
    }

    // Update Dialog
    UpdateDialog {
        show <=> root.show-update-dialog;
        checking <=> root.update-checking;
        update-available <=> root.update-available;
        current-version <=> root.update-current-version;
        latest-version <=> root.update-latest-version;
        release-notes <=> root.update-release-notes;
        error-message <=> root.update-error-message;
        dont-check-again <=> root.update-dont-check-again;

        close-clicked => { root.update-close(); }
        download-clicked => { root.update-download(); }
        skip-clicked => { root.update-skip(); }
    }

    // Papyrus Dialog
    PapyrusDialog {
        show <=> root.show-papyrus-dialog;
        monitoring <=> root.papyrus-monitoring;
        log-path <=> root.papyrus-log-path;
        error-count <=> root.papyrus-error-count;
        warning-count <=> root.papyrus-warning-count;
        info-count <=> root.papyrus-info-count;
        dumps-count <=> root.papyrus-dumps-count;     // NEW
        stacks-count <=> root.papyrus-stacks-count;   // NEW
        log-content <=> root.papyrus-log-content;

        close-clicked => { root.papyrus-close(); }
        start-monitoring => { root.papyrus-start-monitoring(); }
        stop-monitoring => { root.papyrus-stop-monitoring(); }
        clear-stats => { root.papyrus-clear-stats(); }
        update-stats => { root.papyrus-update-stats(); }  // NEW
    }

    // Confirmation Dialog
    ConfirmationDialog {
        show <=> root.show-confirmation-dialog;
        title <=> root.confirmation-title;
        message <=> root.confirmation-message;
        confirm-text <=> root.confirmation-confirm-text;
        cancel-text <=> root.confirmation-cancel-text;
        is-danger <=> root.confirmation-is-danger;

        confirmed => { root.confirmation-confirmed(); }
        cancelled => { root.confirmation-cancelled(); }
    }

    // Help Dialog
    HelpDialog {
        show <=> root.show-help-dialog;
        title <=> root.help-title;
        content <=> root.help-content;
        related-topics <=> root.help-related-topics;

        close-clicked => { root.help-close(); }
        related-topic-clicked(category, topic) => { root.help-show-topic(category, topic); }
    }

    // Pastebin Dialog
    PastebinDialog {
        show <=> root.show-pastebin-dialog;
        url-input <=> root.pastebin-url-input;
        is-loading <=> root.pastebin-loading;

        open-clicked => { root.pastebin-open(); }
        cancel-clicked => { root.pastebin-cancel(); }
    }
}