import { FluentDark } from "../styles/fluent_dark.slint";

// ReportListItem - Individual report item in the list with Fluent styling
// Displays report filename and metadata with interactive states
export component ReportListItem inherits Rectangle {
    // Properties
    in property <string> filename;
    in property <string> display-date;
    in property <string> file-size;
    in property <bool> selected: false;

    // Callback
    callback clicked();

    // Styling
    background: root.selected ? FluentDark.accent : FluentDark.layer2;
    border-radius: FluentDark.radius-sm;
    height: 64px;

    // Subtle border for definition
    border-width: 1px;
    border-color: root.selected ? FluentDark.accent : FluentDark.border-subtle;

    // Touch area for interaction
    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    // State management
    states [
        hover when touch.has-hover && !root.selected: {
            background: FluentDark.hover;
            border-color: FluentDark.border;
        }
        pressed when touch.pressed && !root.selected: {
            background: FluentDark.pressed;
        }
    ]

    // Animate background and border changes
    animate background, border-color {
        duration: FluentDark.animation-fast;
        easing: ease-in-out;
    }

    // Content layout
    HorizontalLayout {
        padding: FluentDark.spacing-sm;
        spacing: FluentDark.spacing-sm;

        VerticalLayout {
            spacing: 4px;
            vertical-stretch: 1;

            // Filename (primary text)
            Text {
                text: root.filename;
                color: root.selected ? FluentDark.text-on-accent : FluentDark.text-primary;
                font-size: FluentDark.font-size-base;
                font-weight: FluentDark.font-weight-semibold;
                overflow: elide;
                vertical-alignment: center;
            }

            // Metadata row (date and size)
            HorizontalLayout {
                spacing: FluentDark.spacing-sm;

                Text {
                    text: root.display-date;
                    color: root.selected ? FluentDark.text-on-accent : FluentDark.text-secondary;
                    font-size: FluentDark.font-size-sm;
                    font-weight: FluentDark.font-weight-regular;
                    overflow: elide;
                }

                Text {
                    text: "•";
                    color: root.selected ? FluentDark.text-on-accent : FluentDark.text-secondary;
                    font-size: FluentDark.font-size-sm;
                }

                Text {
                    text: root.file-size;
                    color: root.selected ? FluentDark.text-on-accent : FluentDark.text-secondary;
                    font-size: FluentDark.font-size-sm;
                    font-weight: FluentDark.font-weight-regular;
                    overflow: elide;
                }
            }
        }
    }
}
