import { FluentDark } from "../styles/fluent_dark.slint";
import { FolderBrowseButton } from "folder_browse_button.slint";

// FolderSelector - Folder selection component with text input and browse button
// Uses FluentCard styling for elevated appearance
export component FolderSelector inherits Rectangle {
    // Properties
    in property<string> label-text: "FOLDER";
    in-out property<string> folder-path: "";
    in property<string> placeholder: "Select a folder...";
    in property<bool> enabled: true;

    // Callbacks
    callback browse-clicked();
    callback path-changed(/* new-path */ string);
    callback editing-finished();

    // Layout
    background: transparent;
    min-height: 45px;

    VerticalLayout {
        spacing: 4px;

        // Label
        Text {
            text: root.label-text;
            color: FluentDark.text-secondary;
            font-size: FluentDark.font-size-sm;
            font-weight: FluentDark.font-weight-regular;
        }

        // Input container with Fluent styling
        HorizontalLayout {
            spacing: FluentDark.spacing-sm;

            // Text input field
            Rectangle {
                background: FluentDark.layer3;
                border-radius: FluentDark.radius-sm;
                border-width: 1px;
                border-color: input-focus ? FluentDark.focus-border : FluentDark.border;
                clip: true;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    padding-top: 6px;
                    padding-bottom: 6px;
                    alignment: start;

                    input := TextInput {
                        text <=> root.folder-path;
                        color: FluentDark.text-primary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-regular;
                        enabled: root.enabled;
                        horizontal-alignment: left;
                        vertical-alignment: center;

                        accepted => {
                            root.path-changed(self.text);
                        }
                        edited => {
                            root.path-changed(self.text);
                        }
                    }

                    // Show placeholder text when input is empty
                    if root.folder-path == "": Text {
                        text: root.placeholder;
                        color: FluentDark.text-tertiary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: left;
                        vertical-alignment: center;
                    }
                }

                // Animate border color on focus
                animate border-color {
                    duration: FluentDark.animation-fast;
                    easing: ease-in-out;
                }

                // State management for focus
                states [
                    focused when input.has-focus: {
                        border-color: FluentDark.focus-border;
                        border-width: 2px;
                    }
                ]
            }

            // Browse button
            FolderBrowseButton {
                enabled: root.enabled;
                clicked => {
                    root.browse-clicked();
                }
            }
        }
    }

    // Helper property to track input focus
    property<bool> input-focus: input.has-focus;
}
