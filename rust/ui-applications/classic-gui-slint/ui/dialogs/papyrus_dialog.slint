import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "../components/fluent_button.slint";
import { FluentCard } from "../components/fluent_card.slint";

// PapyrusDialog - Real-time Papyrus log monitoring dialog
export component PapyrusDialog inherits Rectangle {
    // Properties
    in property<bool> show: false;
    in property<bool> monitoring: false;
    in property<string> log-path: "";
    in property<int> error-count: 0;
    in property<int> warning-count: 0;
    in property<int> info-count: 0;
    in property<int> dumps-count: 0;   // NEW: Stack dumps count
    in property<int> stacks-count: 0;  // NEW: Stack frames count
    in property<string> log-content: "";

    // Callbacks
    callback close-clicked();
    callback start-monitoring();
    callback stop-monitoring();
    callback clear-stats();
    callback update-stats();  // NEW: Periodically polls and updates stats from Rust

    // Only visible when show is true
    visible: root.show;

    // Stats update timer (runs every second when monitoring is active)
    stats-timer := Timer {
        interval: 1000ms;
        running: root.monitoring;
        triggered => {
            root.update-stats();
        }
    }

    // Full screen overlay
    width: 100%;
    height: 100%;

    // Semi-transparent backdrop
    background: #00000080;

    // Animate fade in/out
    animate opacity {
        duration: FluentDark.animation-normal;
        easing: ease-in-out;
    }

    states [
        visible when root.show: {
            opacity: 1;
        }
        hidden when !root.show: {
            opacity: 0;
        }
    ]

    // Focus scope for keyboard handling
    FocusScope {
        enabled: root.show;

        // Handle Escape key to close dialog
        key-pressed(event) => {
            if (event.text == "\u{001b}") {
                root.close-clicked();
                return accept;
            }
            return reject;
        }

        // Center the dialog
        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                alignment: center;

                // Papyrus monitoring dialog card
                Rectangle {
                background: FluentDark.layer2;
                border-radius: FluentDark.radius-lg;
                border-width: 1px;
                border-color: FluentDark.border;
                min-width: 700px;
                max-width: 900px;
                height: 600px;

                // Elevated shadow
                drop-shadow-blur: FluentDark.shadow-lg;
                drop-shadow-color: #00000060;
                drop-shadow-offset-y: 8px;

                // Animate scale in/out
                animate y {
                    duration: FluentDark.animation-normal;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1);
                }

                VerticalLayout {
                    padding: 0px;
                    spacing: 0px;

                    // Title bar
                    Rectangle {
                        background: FluentDark.layer1;
                        height: 48px;
                        border-radius: FluentDark.radius-lg;

                        HorizontalLayout {
                            padding: FluentDark.spacing-md;
                            spacing: FluentDark.spacing-sm;

                            Text {
                                text: "Papyrus Log Monitoring";
                                color: FluentDark.text-primary;
                                font-size: FluentDark.font-size-xl;
                                font-weight: FluentDark.font-weight-semibold;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            // Status indicator
                            Rectangle {
                                width: 12px;
                                height: 12px;
                                border-radius: 6px;
                                background: root.monitoring ? FluentDark.success : FluentDark.text-tertiary;

                                // Pulse animation when monitoring
                                animate opacity {
                                    duration: 1000ms;
                                    easing: ease-in-out;
                                    iteration-count: -1;  // Infinite loop
                                }

                                states [
                                    monitoring when root.monitoring: {
                                        opacity: 0.3;
                                    }
                                ]
                            }

                            Text {
                                text: root.monitoring ? "Active" : "Stopped";
                                color: root.monitoring ? FluentDark.success : FluentDark.text-tertiary;
                                font-size: FluentDark.font-size-sm;
                                font-weight: FluentDark.font-weight-semibold;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Content area
                    VerticalLayout {
                        padding: FluentDark.spacing-lg;
                        spacing: FluentDark.spacing-md;

                        // Log file path
                        VerticalLayout {
                            spacing: FluentDark.spacing-xs;

                            Text {
                                text: "Log File:";
                                color: FluentDark.text-secondary;
                                font-size: FluentDark.font-size-sm;
                                font-weight: FluentDark.font-weight-semibold;
                            }

                            Text {
                                text: root.log-path != "" ? root.log-path : "No log file configured";
                                color: root.log-path != "" ? FluentDark.text-primary : FluentDark.text-tertiary;
                                font-size: FluentDark.font-size-sm;
                                wrap: word-wrap;
                            }
                        }

                        // Statistics cards
                        HorizontalLayout {
                            spacing: FluentDark.spacing-sm;

                            // Errors card
                            Rectangle {
                                background: FluentDark.layer3;
                                border-radius: FluentDark.radius-md;
                                border-width: 1px;
                                border-color: FluentDark.error;
                                horizontal-stretch: 1;

                                VerticalLayout {
                                    padding: FluentDark.spacing-md;
                                    spacing: FluentDark.spacing-xs;

                                    Text {
                                        text: "Errors";
                                        color: FluentDark.text-secondary;
                                        font-size: FluentDark.font-size-sm;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: root.error-count;
                                        color: FluentDark.error;
                                        font-size: FluentDark.font-size-2xl;
                                        font-weight: FluentDark.font-weight-bold;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Warnings card
                            Rectangle {
                                background: FluentDark.layer3;
                                border-radius: FluentDark.radius-md;
                                border-width: 1px;
                                border-color: FluentDark.warning;
                                horizontal-stretch: 1;

                                VerticalLayout {
                                    padding: FluentDark.spacing-md;
                                    spacing: FluentDark.spacing-xs;

                                    Text {
                                        text: "Warnings";
                                        color: FluentDark.text-secondary;
                                        font-size: FluentDark.font-size-sm;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: root.warning-count;
                                        color: FluentDark.warning;
                                        font-size: FluentDark.font-size-2xl;
                                        font-weight: FluentDark.font-weight-bold;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Info card
                            Rectangle {
                                background: FluentDark.layer3;
                                border-radius: FluentDark.radius-md;
                                border-width: 1px;
                                border-color: FluentDark.info;
                                horizontal-stretch: 1;

                                VerticalLayout {
                                    padding: FluentDark.spacing-md;
                                    spacing: FluentDark.spacing-xs;

                                    Text {
                                        text: "Info";
                                        color: FluentDark.text-secondary;
                                        font-size: FluentDark.font-size-sm;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: root.info-count;
                                        color: FluentDark.info;
                                        font-size: FluentDark.font-size-2xl;
                                        font-weight: FluentDark.font-weight-bold;
                                        horizontal-alignment: center;
                                    }
                                }
                            }
                        }

                        // Dumps and Stacks statistics (second row)
                        HorizontalLayout {
                            spacing: FluentDark.spacing-sm;

                            // Dumps card
                            Rectangle {
                                background: FluentDark.layer3;
                                border-radius: FluentDark.radius-md;
                                border-width: 1px;
                                border-color: FluentDark.text-secondary;
                                horizontal-stretch: 1;

                                VerticalLayout {
                                    padding: FluentDark.spacing-md;
                                    spacing: FluentDark.spacing-xs;

                                    Text {
                                        text: "Dumps";
                                        color: FluentDark.text-secondary;
                                        font-size: FluentDark.font-size-sm;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: root.dumps-count;
                                        color: FluentDark.accent;
                                        font-size: FluentDark.font-size-2xl;
                                        font-weight: FluentDark.font-weight-bold;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Stacks card
                            Rectangle {
                                background: FluentDark.layer3;
                                border-radius: FluentDark.radius-md;
                                border-width: 1px;
                                border-color: FluentDark.text-secondary;
                                horizontal-stretch: 1;

                                VerticalLayout {
                                    padding: FluentDark.spacing-md;
                                    spacing: FluentDark.spacing-xs;

                                    Text {
                                        text: "Stacks";
                                        color: FluentDark.text-secondary;
                                        font-size: FluentDark.font-size-sm;
                                        horizontal-alignment: center;
                                    }

                                    Text {
                                        text: root.stacks-count;
                                        color: FluentDark.accent;
                                        font-size: FluentDark.font-size-2xl;
                                        font-weight: FluentDark.font-weight-bold;
                                        horizontal-alignment: center;
                                    }
                                }
                            }

                            // Spacer to align with above row (since we only have 2 cards here)
                            Rectangle {
                                horizontal-stretch: 1;
                                background: transparent;
                            }
                        }

                        // Log viewer
                        VerticalLayout {
                            spacing: FluentDark.spacing-xs;

                            HorizontalLayout {
                                spacing: FluentDark.spacing-sm;

                                Text {
                                    text: "Recent Log Entries:";
                                    color: FluentDark.text-secondary;
                                    font-size: FluentDark.font-size-sm;
                                    font-weight: FluentDark.font-weight-semibold;
                                    horizontal-stretch: 1;
                                }

                                FluentButton {
                                    text: "Clear Stats";
                                    primary: false;
                                    clicked => {
                                        root.clear-stats();
                                    }
                                }
                            }

                            Rectangle {
                                background: FluentDark.background;
                                border-radius: FluentDark.radius-sm;
                                border-width: 1px;
                                border-color: FluentDark.border;
                                height: 250px;

                                Flickable {
                                    width: 100%;
                                    viewport-height: 500px;

                                    Text {
                                        text: root.log-content != "" ? root.log-content : "No log entries yet...";
                                        color: root.log-content != "" ? FluentDark.text-primary : FluentDark.text-tertiary;
                                        font-size: FluentDark.font-size-sm;
                                        font-family: "Cascadia Mono";
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }

                    // Bottom button bar
                    Rectangle {
                        background: FluentDark.layer1;
                        height: 56px;

                        HorizontalLayout {
                            padding: FluentDark.spacing-md;
                            spacing: FluentDark.spacing-sm;
                            alignment: end;

                            FluentButton {
                                text: "Close";
                                primary: false;
                                clicked => {
                                    root.close-clicked();
                                }
                            }

                            if !root.monitoring: FluentButton {
                                text: "Start Monitoring";
                                primary: true;
                                clicked => {
                                    root.start-monitoring();
                                }
                            }

                            if root.monitoring: FluentButton {
                                text: "Stop Monitoring";
                                primary: true;
                                clicked => {
                                    root.stop-monitoring();
                                }
                            }
                        }
                    }
                }
            }
        }  // End HorizontalLayout (center)
    }  // End VerticalLayout (center)

    // Handle click outside to close
    TouchArea {
            clicked => {
                root.close-clicked();
            }
        }
    }  // End FocusScope
}
