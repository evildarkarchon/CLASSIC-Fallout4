import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "../components/fluent_button.slint";
import { FolderSelector } from "../components/folder_selector.slint";
import { PapyrusButton } from "../components/papyrus_button.slint";
import { ErrorDialog } from "../components/error_dialog.slint";
import { SuccessDialog } from "../components/success_dialog.slint";
import { ProgressSpinner } from "../components/progress_spinner.slint";

// MainTab - Main options tab with folder selectors, scan buttons, and utility buttons
export component MainTab inherits Rectangle {
    // Properties
    in-out property<string> mods-folder-path: "";
    in-out property<string> scan-folder-path: "";
    in-out property<bool> scan-in-progress: false;
    in-out property<bool> papyrus-monitoring: false;

    // Dialog properties
    in-out property<bool> show-error-dialog: false;
    in-out property<string> error-title: "Error";
    in-out property<string> error-message: "";
    in-out property<string> error-details: "";

    in-out property<bool> show-success-dialog: false;
    in-out property<string> success-title: "Success";
    in-out property<string> success-message: "";

    // Callbacks
    callback browse-mods-folder();
    callback browse-scan-folder();
    callback scan-crash-logs();
    callback scan-game-files();
    callback show-about();
    callback show-help();
    callback open-settings();
    callback open-crash-logs-folder();
    callback check-updates();
    callback toggle-papyrus();
    callback exit-app();
    callback copy-error-to-clipboard();

    background: FluentDark.background;

    VerticalLayout {
        padding: FluentDark.spacing-md;
        spacing: 0;

        // ========================================
        // HEADER SECTION (Fixed height - 100px)
        // ========================================
        header-widget := Rectangle {
            background: transparent;
            height: 100px;

            VerticalLayout {
                spacing: 5px;
                padding: 0px;

                // Staging Mods Folder
                FolderSelector {
                    label-text: "STAGING MODS FOLDER";
                    folder-path <=> root.mods-folder-path;
                    placeholder: "Optional: Select your mod staging folder (e.g., MO2/mods)";
                    enabled: !root.scan-in-progress;
                    browse-clicked => {
                        root.browse-mods-folder();
                    }
                }

                // Custom Scan Folder
                FolderSelector {
                    label-text: "CUSTOM SCAN FOLDER";
                    folder-path <=> root.scan-folder-path;
                    placeholder: "Optional: Select a supplementary custom folder with crash logs";
                    enabled: !root.scan-in-progress;
                    browse-clicked => {
                        root.browse-scan-folder();
                    }
                }
            }
        }

        // Small spacing after header
        Rectangle {
            height: 5px;
            background: transparent;
        }

        // Stretch to push main buttons to center
        Rectangle {
            background: transparent;
        }

        // ========================================
        // MAIN SCAN BUTTONS
        // ========================================
        main-buttons-layout := HorizontalLayout {
            spacing: FluentDark.spacing-md;
            padding-left: FluentDark.spacing-sm;
            padding-right: FluentDark.spacing-sm;
            padding-top: 0px;
            padding-bottom: 0px;

            FluentButton {
                text: "SCAN CRASH LOGS";
                primary: true;
                enabled: !root.scan-in-progress;
                clicked => {
                    root.scan-crash-logs();
                }
                horizontal-stretch: 1;
            }

            FluentButton {
                text: "SCAN GAME FILES";
                primary: true;
                enabled: !root.scan-in-progress;
                clicked => {
                    root.scan-game-files();
                }
                horizontal-stretch: 1;
            }
        }

        // Stretch to push bottom buttons to bottom
        Rectangle {
            background: transparent;
        }

        // Small spacing before bottom buttons
        Rectangle {
            height: FluentDark.spacing-md;
            background: transparent;
        }

        // ========================================
        // BOTTOM UTILITY BUTTONS - ROW 1
        // ========================================
        bottom-row1-layout := HorizontalLayout {
            spacing: 4px;  // Reduced spacing to fit more buttons
            padding-left: FluentDark.spacing-sm;
            padding-right: FluentDark.spacing-sm;
            padding-top: 0px;
            padding-bottom: 0px;

            FluentButton {
                text: "ABOUT";
                primary: false;
                clicked => {
                    root.show-about();
                }
            }

            FluentButton {
                text: "HELP";
                primary: false;
                clicked => {
                    root.show-help();
                }
            }

            FluentButton {
                text: "SETTINGS";
                primary: false;
                clicked => {
                    root.open-settings();
                }
            }

            FluentButton {
                text: "OPEN LOGS";  // Shortened text
                primary: false;
                clicked => {
                    root.open-crash-logs-folder();
                }
            }

            FluentButton {
                text: "UPDATES";  // Shortened text
                primary: false;
                clicked => {
                    root.check-updates();
                }
            }
        }

        // Small spacing between button rows
        Rectangle {
            height: 5px;
            background: transparent;
        }

        // ========================================
        // BOTTOM UTILITY BUTTONS - ROW 2
        // ========================================
        bottom-row2-layout := HorizontalLayout {
            spacing: 4px;  // Reduced spacing
            padding-left: FluentDark.spacing-sm;
            padding-right: FluentDark.spacing-sm;
            padding-top: 0px;
            padding-bottom: 0px;

            // Papyrus button takes up most of the space
            PapyrusButton {
                monitoring <=> root.papyrus-monitoring;
                enabled: true;
                clicked => {
                    root.toggle-papyrus();
                }
                horizontal-stretch: 3;  // Give it more space
            }

            // Exit button
            FluentButton {
                text: "EXIT";
                primary: false;
                clicked => {
                    root.exit-app();
                }
                horizontal-stretch: 1;  // Give it less space
            }
        }
    }

    // ========================================
    // DIALOGS (Overlay on top of everything)
    // ========================================
    ErrorDialog {
        show <=> root.show-error-dialog;
        title <=> root.error-title;
        message <=> root.error-message;
        details <=> root.error-details;
        ok-clicked => {
            root.show-error-dialog = false;
        }
        copy-to-clipboard => {
            root.copy-error-to-clipboard();
        }
    }

    SuccessDialog {
        show <=> root.show-success-dialog;
        title <=> root.success-title;
        message <=> root.success-message;
        ok-clicked => {
            root.show-success-dialog = false;
        }
    }

    // Progress spinner (centered overlay during scans)
    if root.scan-in-progress: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000040;

        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                alignment: center;

                ProgressSpinner {
                    active: root.scan-in-progress;
                    size: 64px;
                }
            }
        }
    }
}
