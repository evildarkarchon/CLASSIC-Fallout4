import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "../components/fluent_button.slint";
import { ReportList, ReportData } from "../components/report_list.slint";
import { SplitPane } from "../components/split_pane.slint";
import { MarkdownViewer, MarkdownMetadata } from "../components/markdown_viewer.slint";

// ResultsTab - Results viewer tab with split pane layout
// Left panel: Report list with management buttons
// Right panel: Markdown viewer with zoom and copy controls
export component ResultsTab inherits Rectangle {
    // Properties
    in property <[ReportData]> reports: [];
    in-out property <int> selected-report-index: -1;
    in-out property <string> selected-report-path: "";
    in-out property <string> markdown-content: "";
    in-out property <MarkdownMetadata> markdown-metadata: {
        filename: "",
        file-size: "",
        display-date: ""
    };
    in-out property <int> zoom-level: 100;

    // Callbacks for report operations
    callback refresh-reports();
    callback delete-report();
    callback open-reports-folder();
    callback report-selected(string);  // path

    // Callbacks for markdown viewer
    callback copy-to-clipboard();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();

    background: FluentDark.background;

    VerticalLayout {
        padding: FluentDark.spacing-md;
        spacing: 0;

        // Split pane layout (30% left, 70% right)
        SplitPane {
            left-min-width: 250px;
            right-min-width: 400px;
            split-position: 300px;

            // LEFT PANEL - Report list and buttons
            VerticalLayout {
                spacing: FluentDark.spacing-sm;

                // Report list
                report-list := ReportList {
                    reports: root.reports;
                    selected-index: root.selected-report-index;
                    vertical-stretch: 1;

                    report-selected(index, path) => {
                        root.selected-report-index = index;
                        root.selected-report-path = path;
                        root.report-selected(path);
                    }
                }

                // Button bar
                HorizontalLayout {
                    spacing: FluentDark.spacing-sm;
                    height: FluentDark.button-height;

                    FluentButton {
                        text: "Refresh";
                        primary: false;
                        enabled: true;
                        clicked => { root.refresh-reports(); }
                    }

                    FluentButton {
                        text: "Delete";
                        primary: false;
                        enabled: root.selected-report-index >= 0;
                        clicked => { root.delete-report(); }
                    }

                    FluentButton {
                        text: "Open Folder";
                        primary: false;
                        enabled: true;
                        clicked => { root.open-reports-folder(); }
                    }
                }
            }

            // RIGHT PANEL - Markdown viewer with zoom and copy controls
            MarkdownViewer {
                markdown-text: root.markdown-content;
                metadata: root.markdown-metadata;
                zoom-level <=> root.zoom-level;

                copy-to-clipboard => { root.copy-to-clipboard(); }
                zoom-in => { root.zoom-in(); }
                zoom-out => { root.zoom-out(); }
                zoom-reset => { root.zoom-reset(); }
            }
        }
    }
}