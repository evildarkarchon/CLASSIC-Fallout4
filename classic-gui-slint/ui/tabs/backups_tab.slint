import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentCard } from "../components/fluent_card.slint";
import { FluentButton } from "../components/fluent_button.slint";
import { FluentDialog } from "../components/fluent_dialog.slint";
import { ProgressSpinner } from "../components/progress_spinner.slint";

// BackupSection component - Reusable section for each backup category
// Must be defined before BackupsTab to be used inside it
component BackupSection inherits FluentCard {
    // Properties
    in property<string> title: "CATEGORY";
    in property<bool> backup-exists: false;
    in property<bool> operation-in-progress: false;

    // Callbacks
    callback backup-clicked();
    callback restore-clicked();
    callback remove-clicked();

    VerticalLayout {
        spacing: FluentDark.spacing-sm;

        // Title
        Text {
            text: root.title;
            color: FluentDark.text-primary;
            font-size: FluentDark.font-size-base;
            font-weight: FluentDark.font-weight-semibold;
            horizontal-alignment: center;
        }

        // Buttons row
        HorizontalLayout {
            spacing: FluentDark.spacing-sm;

            FluentButton {
                text: "BACKUP";
                primary: false;
                enabled: !root.operation-in-progress;
                clicked => { root.backup-clicked(); }
            }

            FluentButton {
                text: "RESTORE";
                primary: false;
                enabled: root.backup-exists && !root.operation-in-progress;
                clicked => { root.restore-clicked(); }
            }

            FluentButton {
                text: "REMOVE";
                primary: false;
                enabled: !root.operation-in-progress;
                clicked => { root.remove-clicked(); }
            }
        }
    }
}

// BackupsTab - File backup operations tab
export component BackupsTab inherits Rectangle {
    background: FluentDark.background;

    // Properties for state management
    in-out property<bool> operation-in-progress: false;

    // Backup state for each category (enabled/disabled RESTORE buttons)
    in-out property<bool> xse-backup-exists: false;
    in-out property<bool> reshade-backup-exists: false;
    in-out property<bool> vulkan-backup-exists: false;
    in-out property<bool> enb-backup-exists: false;

    // Confirmation dialog properties
    in-out property<bool> show-confirmation: false;
    in-out property<string> confirmation-title: "Confirm Operation";
    in-out property<string> confirmation-message: "Are you sure?";

    // Callbacks for backup operations (12 total: 4 categories × 3 operations)
    callback backup-xse();
    callback restore-xse();
    callback remove-xse();

    callback backup-reshade();
    callback restore-reshade();
    callback remove-reshade();

    callback backup-vulkan();
    callback restore-vulkan();
    callback remove-vulkan();

    callback backup-enb();
    callback restore-enb();
    callback remove-enb();

    callback open-backups-folder();

    // Confirmation dialog callbacks
    callback confirm-operation();
    callback cancel-operation();

    VerticalLayout {
        padding: FluentDark.spacing-md;
        spacing: FluentDark.spacing-md;
        alignment: start;

        // Information section
        FluentCard {
            VerticalLayout {
                spacing: FluentDark.spacing-sm;

                Text {
                    text: "BACKUP > Backup files from the game folder into the CLASSIC Backup folder.";
                    color: FluentDark.text-secondary;
                    font-size: FluentDark.font-size-sm;
                    font-weight: FluentDark.font-weight-regular;
                    wrap: word-wrap;
                }

                Text {
                    text: "RESTORE > Restore file backup from the CLASSIC Backup folder into the game folder.";
                    color: FluentDark.text-secondary;
                    font-size: FluentDark.font-size-sm;
                    font-weight: FluentDark.font-weight-regular;
                    wrap: word-wrap;
                }

                Text {
                    text: "REMOVE > Remove files only from the game folder without removing existing backups.";
                    color: FluentDark.text-secondary;
                    font-size: FluentDark.font-size-sm;
                    font-weight: FluentDark.font-weight-regular;
                    wrap: word-wrap;
                }
            }
        }

        // Scrollable area for backup sections
        Flickable {
            viewport-height: sections-layout.preferred-height;

            sections-layout := VerticalLayout {
                spacing: FluentDark.spacing-md;

                // XSE Section
                BackupSection {
                    title: "XSE FILES";
                    backup-exists: root.xse-backup-exists;
                    operation-in-progress: root.operation-in-progress;

                    backup-clicked => { root.backup-xse(); }
                    restore-clicked => { root.restore-xse(); }
                    remove-clicked => { root.remove-xse(); }
                }

                // RESHADE Section
                BackupSection {
                    title: "RESHADE FILES";
                    backup-exists: root.reshade-backup-exists;
                    operation-in-progress: root.operation-in-progress;

                    backup-clicked => { root.backup-reshade(); }
                    restore-clicked => { root.restore-reshade(); }
                    remove-clicked => { root.remove-reshade(); }
                }

                // VULKAN Section
                BackupSection {
                    title: "VULKAN FILES";
                    backup-exists: root.vulkan-backup-exists;
                    operation-in-progress: root.operation-in-progress;

                    backup-clicked => { root.backup-vulkan(); }
                    restore-clicked => { root.restore-vulkan(); }
                    remove-clicked => { root.remove-vulkan(); }
                }

                // ENB Section
                BackupSection {
                    title: "ENB FILES";
                    backup-exists: root.enb-backup-exists;
                    operation-in-progress: root.operation-in-progress;

                    backup-clicked => { root.backup-enb(); }
                    restore-clicked => { root.restore-enb(); }
                    remove-clicked => { root.remove-enb(); }
                }
            }
        }

        // Bottom bar with open backups button
        HorizontalLayout {
            alignment: end;

            FluentButton {
                text: "OPEN CLASSIC BACKUPS";
                primary: false;
                enabled: !root.operation-in-progress;
                clicked => { root.open-backups-folder(); }
            }
        }

        // Progress spinner overlay (shown during operations)
        if root.operation-in-progress: ProgressSpinner {
            size: 64px;
        }
    }

    // Confirmation dialog
    FluentDialog {
        show: root.show-confirmation;
        title: root.confirmation-title;
        message: root.confirmation-message;
        show-cancel: true;
        ok-text: "Yes";
        cancel-text: "No";

        ok-clicked => { root.confirm-operation(); }
        cancel-clicked => { root.cancel-operation(); }
        closed => { root.show-confirmation = false; }
    }
}
