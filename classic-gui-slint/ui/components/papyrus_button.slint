import { FluentDark } from "../styles/fluent_dark.slint";

// PapyrusButton - Toggle button with semantic colors (green START, red STOP)
// Special button for Papyrus monitoring with state-dependent styling
export component PapyrusButton inherits Rectangle {
    // Properties
    in-out property<bool> monitoring: false;
    in property<bool> enabled: true;

    // Callback
    callback clicked <=> touch.clicked;

    // Computed properties based on monitoring state
    property<string> button-text: monitoring ? "STOP PAPYRUS MONITORING" : "START PAPYRUS MONITORING";
    property<color> base-color: monitoring ? FluentDark.papyrus-stop : FluentDark.papyrus-start;
    property<color> hover-color: monitoring
        ? #d42626  // Darker red on hover
        : #26d479; // Darker green on hover
    property<color> pressed-color: monitoring
        ? #ba2121  // Even darker red when pressed
        : #21ba69; // Even darker green when pressed

    // Styling
    background: root.base-color;
    border-radius: 10px;
    border-width: 1px;
    border-color: #000000;
    min-height: FluentDark.button-height;
    // Remove min-width to allow responsive sizing

    // Touch area for interactions
    touch := TouchArea {
        enabled: root.enabled;
    }

    // Animate background color changes
    animate background {
        duration: FluentDark.animation-fast;
        easing: ease-in-out;
    }

    // State management
    states [
        hover when touch.has-hover && root.enabled: {
            background: root.hover-color;
        }
        pressed when touch.pressed && root.enabled: {
            background: root.pressed-color;
        }
        disabled when !root.enabled: {
            background: FluentDark.disabled;
            opacity: 0.5;
        }
    ]

    // Text label
    HorizontalLayout {
        padding-left: FluentDark.spacing-md;
        padding-right: FluentDark.spacing-md;
        padding-top: FluentDark.spacing-sm;
        padding-bottom: FluentDark.spacing-sm;
        alignment: center;

        Text {
            text: root.button-text;
            color: #000000;  // Black text for high contrast on green/red
            font-size: FluentDark.font-size-base;
            font-weight: FluentDark.font-weight-bold;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
