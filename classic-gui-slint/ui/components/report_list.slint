import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentCard } from "./fluent_card.slint";
import { ReportListItem } from "./report_list_item.slint";
import { ScrollView } from "std-widgets.slint";

// Report data structure (matches Rust ReportItem)
export struct ReportData {
    filename: string,
    path: string,
    display-date: string,
    file-size: string,
}

// ReportList - Scrollable list of reports with Fluent styling
export component ReportList inherits FluentCard {
    // Properties
    in property <[ReportData]> reports: [];
    in-out property <int> selected-index: -1;

    // Callbacks
    callback report-selected(int, string);  // index, path

    // Styling
    background: FluentDark.layer1;

    VerticalLayout {
        padding: 0px;
        spacing: 0;

        // Empty state message
        if reports.length == 0: Rectangle {
            background: transparent;
            height: 100%;

            VerticalLayout {
                alignment: center;
                spacing: FluentDark.spacing-md;

                Text {
                    text: "No Reports Found";
                    color: FluentDark.text-secondary;
                    font-size: FluentDark.font-size-lg;
                    font-weight: FluentDark.font-weight-semibold;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Scan crash logs to generate reports";
                    color: FluentDark.text-tertiary;
                    font-size: FluentDark.font-size-base;
                    horizontal-alignment: center;
                }
            }
        }

        // Report list (shown when reports exist)
        if reports.length > 0: ScrollView {
            VerticalLayout {
                padding: FluentDark.spacing-sm;
                spacing: FluentDark.spacing-sm;

                for report[index] in reports: ReportListItem {
                    filename: report.filename;
                    display-date: report.display-date;
                    file-size: report.file-size;
                    selected: index == root.selected-index;

                    clicked => {
                        root.selected-index = index;
                        root.report-selected(index, report.path);
                    }
                }
            }
        }
    }
}
