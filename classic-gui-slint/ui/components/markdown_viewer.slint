import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentCard } from "./fluent_card.slint";
import { FluentButton } from "./fluent_button.slint";
import { ScrollView } from "std-widgets.slint";

// Markdown metadata structure
export struct MarkdownMetadata {
    filename: string,
    file-size: string,
    display-date: string,
}

// MarkdownViewer - Component for displaying markdown reports with Fluent Design
// Features: Metadata display, zoom controls, copy to clipboard, scrollable content
export component MarkdownViewer inherits Rectangle {
    // Properties
    in property <string> markdown-text: "";
    in property <MarkdownMetadata> metadata: {
        filename: "",
        file-size: "",
        display-date: ""
    };
    in-out property <int> zoom-level: 100;  // Percentage: 50, 75, 100, 125, 150

    // Callbacks
    callback copy-to-clipboard();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();

    // Styling
    background: FluentDark.layer1;
    border-radius: FluentDark.radius-md;
    border-width: 1px;
    border-color: FluentDark.border-subtle;

    VerticalLayout {
        spacing: 0;

        // METADATA WIDGET - Top bar with file information
        metadata-card := Rectangle {
            background: FluentDark.layer2;
            border-radius: FluentDark.radius-sm;
            height: 60px;

            HorizontalLayout {
                padding: FluentDark.spacing-md;
                spacing: FluentDark.spacing-lg;
                alignment: space-between;

                // Left side - File info
                HorizontalLayout {
                    spacing: FluentDark.spacing-lg;
                    alignment: start;

                    // Filename
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;

                        Text {
                            text: "FILENAME";
                            color: FluentDark.text-tertiary;
                            font-size: FluentDark.font-size-sm;
                            font-weight: FluentDark.font-weight-semibold;
                        }

                        Text {
                            text: root.metadata.filename;
                            color: FluentDark.text-primary;
                            font-size: FluentDark.font-size-base;
                            overflow: elide;
                            max-width: 300px;
                        }
                    }

                    // File size
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;

                        Text {
                            text: "SIZE";
                            color: FluentDark.text-tertiary;
                            font-size: FluentDark.font-size-sm;
                            font-weight: FluentDark.font-weight-semibold;
                        }

                        Text {
                            text: root.metadata.file-size;
                            color: FluentDark.text-secondary;
                            font-size: FluentDark.font-size-base;
                        }
                    }

                    // Date modified
                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;

                        Text {
                            text: "DATE";
                            color: FluentDark.text-tertiary;
                            font-size: FluentDark.font-size-sm;
                            font-weight: FluentDark.font-weight-semibold;
                        }

                        Text {
                            text: root.metadata.display-date;
                            color: FluentDark.text-secondary;
                            font-size: FluentDark.font-size-base;
                        }
                    }
                }

                // Right side - Toolbar
                HorizontalLayout {
                    spacing: FluentDark.spacing-sm;
                    alignment: end;

                    // Zoom out button
                    FluentButton {
                        text: "−";
                        primary: false;
                        enabled: root.zoom-level > 50;
                        min-width: 32px;
                        max-width: 32px;
                        clicked => { root.zoom-out(); }
                    }

                    // Zoom level display
                    Text {
                        text: root.zoom-level + "%";
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-semibold;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                        min-width: 50px;
                    }

                    // Zoom in button
                    FluentButton {
                        text: "+";
                        primary: false;
                        enabled: root.zoom-level < 150;
                        min-width: 32px;
                        max-width: 32px;
                        clicked => { root.zoom-in(); }
                    }

                    // Reset zoom button
                    FluentButton {
                        text: "100%";
                        primary: false;
                        enabled: root.zoom-level != 100;
                        clicked => { root.zoom-reset(); }
                    }

                    // Copy button
                    FluentButton {
                        text: "Copy";
                        primary: true;
                        enabled: root.markdown-text != "";
                        clicked => { root.copy-to-clipboard(); }
                    }
                }
            }
        }

        // Divider
        Rectangle {
            height: 1px;
            background: FluentDark.border-subtle;
        }

        // MARKDOWN CONTENT - Scrollable text area
        if root.markdown-text == "": Rectangle {
            background: transparent;
            vertical-stretch: 1;

            VerticalLayout {
                alignment: center;
                spacing: FluentDark.spacing-md;

                Text {
                    text: "No Report Selected";
                    color: FluentDark.text-secondary;
                    font-size: FluentDark.font-size-xl;
                    font-weight: FluentDark.font-weight-semibold;
                    horizontal-alignment: center;
                }

                Text {
                    text: "Select a report from the list to view its contents";
                    color: FluentDark.text-tertiary;
                    font-size: FluentDark.font-size-base;
                    horizontal-alignment: center;
                }
            }
        }

        if root.markdown-text != "": ScrollView {
            vertical-stretch: 1;
            viewport-width: self.visible-width;

            VerticalLayout {
                padding-left: FluentDark.spacing-lg;
                padding-right: FluentDark.spacing-lg;
                padding-top: FluentDark.spacing-md;
                padding-bottom: FluentDark.spacing-md;
                spacing: FluentDark.spacing-sm;

                // Markdown content with zoom scaling
                markdown-content := Text {
                    text: root.markdown-text;
                    color: FluentDark.text-primary;
                    font-family: FluentDark.font-family;

                    // Apply zoom level to font size
                    font-size: FluentDark.font-size-base * root.zoom-level / 100;

                    wrap: word-wrap;
                    vertical-alignment: top;
                    horizontal-alignment: left;

                    // Smooth zoom animation
                    animate font-size {
                        duration: FluentDark.animation-fast;
                        easing: ease-in-out;
                    }
                }
            }
        }
    }

    // Visual feedback for empty state
    states [
        empty when root.markdown-text == "": {
            metadata-card.opacity: 0.5;
        }
    ]
}
