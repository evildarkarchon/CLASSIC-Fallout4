import { FluentDark } from "../styles/fluent_dark.slint";

// FluentCard - Elevated surface component with subtle depth
// Used for grouping related content with visual hierarchy
export component FluentCard inherits Rectangle {
    // Card styling with elevation
    background: FluentDark.layer2;
    border-radius: FluentDark.radius-md;
    border-width: 1px;
    border-color: FluentDark.border-subtle;

    // Subtle shadow for depth (Fluent design principle)
    drop-shadow-blur: FluentDark.shadow-sm;
    drop-shadow-color: FluentDark.shadow-color;
    drop-shadow-offset-y: 2px;
    drop-shadow-offset-x: 0px;

    // Note: Padding should be set by content layouts inside the card
}