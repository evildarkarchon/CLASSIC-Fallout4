import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "fluent_button.slint";

// ErrorDialog - Dialog for displaying error messages with semantic red styling
export component ErrorDialog inherits Rectangle {
    // Properties
    in property<string> title: "Error";
    in property<string> message: "";
    in property<string> details: "";  // Traceback/stack trace details
    in property<bool> show: false;
    in-out property<bool> details-expanded: false;  // Toggle for traceback section

    // Callbacks
    callback ok-clicked();
    callback copy-to-clipboard();

    // Only visible when show is true
    visible: root.show;

    // Full screen overlay
    width: 100%;
    height: 100%;

    // Semi-transparent backdrop
    background: #00000080;

    // Animate fade in/out
    animate opacity {
        duration: FluentDark.animation-normal;
        easing: ease-in-out;
    }

    states [
        visible when root.show: {
            opacity: 1;
        }
        hidden when !root.show: {
            opacity: 0;
        }
    ]

    // Center the dialog card
    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            alignment: center;

            // Error dialog card
            Rectangle {
                background: FluentDark.layer2;
                border-radius: FluentDark.radius-lg;
                border-width: 2px;
                border-color: FluentDark.error;  // Red border for errors
                min-width: 400px;
                max-width: 600px;
                min-height: 150px;

                // Elevated shadow with red tint
                drop-shadow-blur: FluentDark.shadow-lg;
                drop-shadow-color: #ed2d2d40;  // Red shadow
                drop-shadow-offset-y: 8px;

                // Animate scale in/out
                animate y {
                    duration: FluentDark.animation-normal;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1);
                }

                VerticalLayout {
                    padding: FluentDark.spacing-lg;
                    spacing: FluentDark.spacing-md;

                    // Title with error icon
                    HorizontalLayout {
                        spacing: FluentDark.spacing-sm;

                        // Error icon (red circle with X)
                        Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: 12px;
                            background: FluentDark.error;

                            Text {
                                text: "✕";
                                color: #ffffff;
                                font-size: 16px;
                                font-weight: FluentDark.font-weight-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: root.title;
                            color: FluentDark.error;
                            font-size: FluentDark.font-size-xl;
                            font-weight: FluentDark.font-weight-semibold;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                    }

                    // Error message
                    Text {
                        text: root.message;
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: left;
                        wrap: word-wrap;
                    }

                    // Collapsible details section (only if details provided)
                    if root.details != "": VerticalLayout {
                        spacing: FluentDark.spacing-sm;

                        // Details header (clickable to expand/collapse)
                        Rectangle {
                            height: 32px;
                            background: details-touch.has-hover ? FluentDark.layer3 : transparent;
                            border-radius: FluentDark.radius-sm;

                            HorizontalLayout {
                                padding-left: FluentDark.spacing-sm;
                                padding-right: FluentDark.spacing-sm;
                                spacing: FluentDark.spacing-xs;

                                // Expand/collapse arrow
                                Text {
                                    text: root.details-expanded ? "▼" : "▶";
                                    color: FluentDark.text-secondary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    width: 16px;
                                }

                                Text {
                                    text: "Details";
                                    color: FluentDark.text-secondary;
                                    font-size: FluentDark.font-size-sm;
                                    font-weight: FluentDark.font-weight-semibold;
                                    vertical-alignment: center;
                                }

                                details-touch := TouchArea {
                                    clicked => {
                                        root.details-expanded = !root.details-expanded;
                                    }
                                }
                            }
                        }

                        // Details content (only when expanded)
                        if root.details-expanded: Rectangle {
                            background: FluentDark.layer1;
                            border-radius: FluentDark.radius-sm;
                            border-width: 1px;
                            border-color: FluentDark.border;
                            max-height: 200px;

                            Flickable {
                                viewport-height: details-text.preferred-height;

                                details-text := Text {
                                    x: FluentDark.spacing-sm;
                                    y: FluentDark.spacing-sm;
                                    width: parent.width - 2 * FluentDark.spacing-sm;
                                    text: root.details;
                                    color: FluentDark.text-secondary;
                                    font-size: 12px;
                                    font-family: "Consolas";  // Monospace for stack traces
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    // Spacer
                    Rectangle {
                        background: transparent;
                    }

                    // Action buttons
                    HorizontalLayout {
                        spacing: FluentDark.spacing-sm;
                        alignment: end;

                        // Copy button (only if details provided)
                        if root.details != "": FluentButton {
                            text: "Copy to Clipboard";
                            primary: false;
                            clicked => {
                                root.copy-to-clipboard();
                            }
                        }

                        FluentButton {
                            text: "OK";
                            primary: true;
                            clicked => {
                                root.ok-clicked();
                            }
                        }
                    }
                }
            }
        }
    }
}