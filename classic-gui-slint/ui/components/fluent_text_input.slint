import { FluentDark } from "../styles/fluent_dark.slint";

// FluentTextInput - Text input component with Fluent Design styling
// Provides editable text field with validation and focus states
export component FluentTextInput inherits Rectangle {
    // Properties
    in property<string> label: "";
    in-out property<string> text: "";
    in property<string> placeholder: "";
    in property<bool> enabled: true;
    in property<bool> read-only: false;
    in property<bool> has-error: false;
    in property<string> error-message: "";

    // Callbacks
    callback edited(string);
    callback accepted();  // Enter key pressed

    // Layout
    height: label != "" ? 64px : 40px;

    VerticalLayout {
        spacing: FluentDark.spacing-xs;
        padding: 0px;

        // Label (if provided)
        if label != "": Text {
            text: root.label;
            color: FluentDark.text-secondary;
            font-size: FluentDark.font-size-sm;
            font-weight: FluentDark.font-weight-semibold;
            horizontal-alignment: left;
        }

        // Input field container
        input-container := Rectangle {
            height: 32px;
            background: root.enabled && !root.read-only ? FluentDark.layer3 : FluentDark.disabled;
            border-radius: FluentDark.radius-sm;
            border-width: 1px;
            border-color: root.has-error
                ? FluentDark.error
                : (input-field.has-focus ? FluentDark.focus-border : FluentDark.border);

            // Animate border color
            animate border-color {
                duration: FluentDark.animation-fast;
                easing: ease-in-out;
            }
            animate background {
                duration: FluentDark.animation-fast;
                easing: ease-in-out;
            }

            // Interactive states
            states [
                hover when touch-area.has-hover && root.enabled && !root.read-only: {
                    background: FluentDark.hover;
                    border-color: root.has-error ? FluentDark.error : FluentDark.border;
                }
                focus when input-field.has-focus: {
                    border-width: 2px;
                    border-color: root.has-error ? FluentDark.error : FluentDark.focus-border;
                }
            ]

            // Placeholder text (shown when input is empty and not focused)
            if root.placeholder != "" && root.text == "" && !input-field.has-focus: Text {
                x: FluentDark.spacing-sm;
                y: (parent.height - self.height) / 2;
                text: root.placeholder;
                color: FluentDark.text-tertiary;
                font-size: FluentDark.font-size-base;
                font-weight: FluentDark.font-weight-regular;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            // Text input field
            input-field := TextInput {
                x: FluentDark.spacing-sm;
                y: (parent.height - self.height) / 2;
                width: parent.width - (2 * FluentDark.spacing-sm);
                text <=> root.text;
                font-size: FluentDark.font-size-base;
                font-weight: FluentDark.font-weight-regular;
                color: root.enabled ? FluentDark.text-primary : FluentDark.text-tertiary;
                selection-foreground-color: FluentDark.text-on-accent;
                selection-background-color: FluentDark.accent;
                horizontal-alignment: left;
                vertical-alignment: center;
                read-only: root.read-only || !root.enabled;

                // Callbacks
                edited => {
                    root.edited(self.text);
                }
                accepted => {
                    root.accepted();
                }
            }

            // Touch area for focus
            touch-area := TouchArea {
                clicked => {
                    if root.enabled && !root.read-only {
                        input-field.focus();
                    }
                }
            }
        }

        // Error message (if has-error is true)
        if root.has-error && root.error-message != "": Text {
            text: root.error-message;
            color: FluentDark.error;
            font-size: FluentDark.font-size-sm;
            font-weight: FluentDark.font-weight-regular;
            horizontal-alignment: left;
            wrap: word-wrap;
        }
    }
}
