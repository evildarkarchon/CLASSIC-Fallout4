import { FluentDark } from "../styles/fluent_dark.slint";

// ProgressBar - Linear progress indicator with Fluent Design styling
// Supports determinate (percentage) and indeterminate (loading) modes
export component ProgressBar inherits Rectangle {
    // Properties
    in property<float> progress: 0.0;  // 0.0 to 1.0
    in property<bool> indeterminate: false;
    in property<length> bar-height: 4px;

    height: root.bar-height;
    background: FluentDark.layer3;
    border-radius: root.bar-height / 2;

    // Progress fill
    progress-fill := Rectangle {
        height: root.bar-height;
        background: FluentDark.accent;
        border-radius: root.bar-height / 2;
        width: root.indeterminate ? 30% : root.progress * root.width;
        x: root.indeterminate ? (root.width * 0.7) * (progress-fill.x-offset / 100) : 0;

        // For indeterminate mode - sliding animation
        property<float> x-offset: 0;

        animate x-offset {
            duration: 1500ms;
            easing: ease-in-out;
            iteration-count: -1;
        }

        animate width {
            duration: FluentDark.animation-normal;
            easing: ease-in-out;
        }

        states [
            indeterminate-slide when root.indeterminate: {
                x-offset: 100;
            }
        ]
    }
}