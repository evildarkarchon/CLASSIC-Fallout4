import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "fluent_button.slint";

// FluentDialog - Base modal dialog component with Fluent Design styling
// Provides overlay, backdrop blur, and elevated card appearance
export component FluentDialog inherits Rectangle {
    // Properties
    in property<string> title: "Dialog";
    in property<string> message: "";
    in property<bool> show: false;
    in property<bool> show-cancel: true;
    in property<string> ok-text: "OK";
    in property<string> cancel-text: "Cancel";

    // Callbacks
    callback ok-clicked();
    callback cancel-clicked();
    callback closed();

    // Only visible when show is true
    visible: root.show;

    // Full screen overlay
    width: 100%;
    height: 100%;

    // Semi-transparent backdrop
    background: #00000080;  // 50% black overlay

    // Animate fade in/out
    animate opacity {
        duration: FluentDark.animation-normal;
        easing: ease-in-out;
    }

    states [
        visible when root.show: {
            opacity: 1;
        }
        hidden when !root.show: {
            opacity: 0;
        }
    ]

    // Center the dialog card
    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            alignment: center;

            // Dialog card
            dialog-card := Rectangle {
                background: FluentDark.layer2;
                border-radius: FluentDark.radius-lg;
                border-width: 1px;
                border-color: FluentDark.border;
                min-width: 400px;
                max-width: 600px;
                min-height: 150px;

                // Elevated shadow
                drop-shadow-blur: FluentDark.shadow-lg;
                drop-shadow-color: #00000060;
                drop-shadow-offset-y: 8px;

                // Animate scale in/out
                animate y {
                    duration: FluentDark.animation-normal;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1);
                }

                VerticalLayout {
                    padding: FluentDark.spacing-lg;
                    spacing: FluentDark.spacing-md;

                    // Title
                    Text {
                        text: root.title;
                        color: FluentDark.text-primary;
                        font-size: FluentDark.font-size-xl;
                        font-weight: FluentDark.font-weight-semibold;
                        horizontal-alignment: left;
                    }

                    // Message content
                    Text {
                        text: root.message;
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: left;
                        wrap: word-wrap;
                    }

                    // Spacer to push buttons to bottom
                    Rectangle {
                        background: transparent;
                    }

                    // Button row
                    HorizontalLayout {
                        spacing: FluentDark.spacing-sm;
                        alignment: end;

                        if root.show-cancel: FluentButton {
                            text: root.cancel-text;
                            primary: false;
                            clicked => {
                                root.cancel-clicked();
                                root.closed();
                            }
                        }

                        FluentButton {
                            text: root.ok-text;
                            primary: true;
                            clicked => {
                                root.ok-clicked();
                                root.closed();
                            }
                        }
                    }
                }
            }
        }
    }

    // Handle click outside to close
    TouchArea {
        clicked => {
            if root.show-cancel {
                root.cancel-clicked();
                root.closed();
            }
        }
    }
}