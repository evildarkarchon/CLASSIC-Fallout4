import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "../components/fluent_button.slint";
import { ScrollView } from "std-widgets.slint";

// Related topic data structure
export struct RelatedTopicData {
    category: string,
    topic: string,
    display: string,
}

// HelpDialog - Context-sensitive help system
// Displays help topics with markdown formatting and related topic links
export component HelpDialog inherits Rectangle {
    // Properties
    in property<bool> show: false;
    in property<string> title: "Help";
    in property<string> content: "";
    in property<[RelatedTopicData]> related-topics: [];

    // Callbacks
    callback close-clicked();
    callback related-topic-clicked(/* category */ string, /* topic */ string);

    // Only visible when show is true
    visible: root.show;

    // Full screen overlay
    width: 100%;
    height: 100%;

    // Semi-transparent backdrop
    background: #00000080;

    // Animate fade in/out
    animate opacity {
        duration: FluentDark.animation-normal;
        easing: ease-in-out;
    }

    states [
        visible when root.show: {
            opacity: 1;
        }
        hidden when !root.show: {
            opacity: 0;
        }
    ]

    // Center the dialog card
    VerticalLayout {
        alignment: center;

        HorizontalLayout {
            alignment: center;

            // Help dialog card
            Rectangle {
                background: FluentDark.layer2;
                border-radius: FluentDark.radius-lg;
                border-width: 1px;
                border-color: FluentDark.border;
                min-width: 500px;
                max-width: 700px;
                min-height: 400px;
                max-height: 600px;

                // Elevated shadow
                drop-shadow-blur: FluentDark.shadow-lg;
                drop-shadow-color: FluentDark.shadow-color;
                drop-shadow-offset-y: 8px;

                VerticalLayout {
                    padding: FluentDark.spacing-lg;
                    spacing: FluentDark.spacing-md;

                    // Header with title and close button
                    HorizontalLayout {
                        spacing: FluentDark.spacing-md;

                        // Help icon
                        Rectangle {
                            width: 32px;
                            height: 32px;
                            border-radius: 16px;
                            background: FluentDark.accent;

                            Text {
                                text: "?";
                                color: #ffffff;
                                font-size: 20px;
                                font-weight: FluentDark.font-weight-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Title
                        Text {
                            text: root.title;
                            color: FluentDark.text-primary;
                            font-size: FluentDark.font-size-xl;
                            font-weight: FluentDark.font-weight-semibold;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        // Close button (X)
                        Rectangle {
                            width: 32px;
                            height: 32px;
                            border-radius: FluentDark.radius-sm;
                            background: close-touch.has-hover ? FluentDark.layer3 : transparent;

                            Text {
                                text: "✕";
                                color: FluentDark.text-secondary;
                                font-size: 18px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            close-touch := TouchArea {
                                clicked => {
                                    root.close-clicked();
                                }
                            }
                        }
                    }

                    // Separator
                    Rectangle {
                        height: 1px;
                        background: FluentDark.border;
                    }

                    // Content area (scrollable text)
                    Rectangle {
                        background: FluentDark.layer1;
                        border-radius: FluentDark.radius-sm;
                        border-width: 1px;
                        border-color: FluentDark.border;
                        vertical-stretch: 1;

                        ScrollView {
                            viewport-width: self.visible-width;

                            VerticalLayout {
                                padding: FluentDark.spacing-md;

                                Text {
                                    text: root.content;
                                    color: FluentDark.text-primary;
                                    font-size: FluentDark.font-size-base;
                                    font-family: FluentDark.font-family;
                                    wrap: word-wrap;
                                    horizontal-alignment: left;
                                    vertical-alignment: top;
                                }
                            }
                        }
                    }

                    // Related topics section (only if topics exist)
                    if root.related-topics.length > 0: VerticalLayout {
                        spacing: FluentDark.spacing-sm;

                        // "Related Topics" header
                        Text {
                            text: "Related Topics:";
                            color: FluentDark.text-secondary;
                            font-size: FluentDark.font-size-sm;
                            font-weight: FluentDark.font-weight-semibold;
                            horizontal-alignment: left;
                        }

                        // Related topics list
                        VerticalLayout {
                            spacing: FluentDark.spacing-xs;

                            for topic in root.related-topics: Rectangle {
                                height: 28px;
                                background: topic-touch.has-hover ? FluentDark.layer3 : transparent;
                                border-radius: FluentDark.radius-sm;

                                HorizontalLayout {
                                    padding-left: FluentDark.spacing-sm;
                                    padding-right: FluentDark.spacing-sm;
                                    spacing: FluentDark.spacing-xs;

                                    // Bullet point
                                    Text {
                                        text: "•";
                                        color: FluentDark.accent;
                                        font-size: FluentDark.font-size-base;
                                        vertical-alignment: center;
                                        width: 16px;
                                    }

                                    // Topic link
                                    Text {
                                        text: topic.display;
                                        color: topic-touch.has-hover ? FluentDark.accent-hover : FluentDark.accent;
                                        font-size: FluentDark.font-size-sm;
                                        vertical-alignment: center;
                                    }

                                    topic-touch := TouchArea {
                                        clicked => {
                                            root.related-topic-clicked(topic.category, topic.topic);
                                        }
                                    }
                                }
                            }
                        }
                    }

                    // Close button
                    HorizontalLayout {
                        alignment: end;

                        FluentButton {
                            text: "Close";
                            primary: true;
                            clicked => {
                                root.close-clicked();
                            }
                        }
                    }
                }
            }
        }
    }
}
