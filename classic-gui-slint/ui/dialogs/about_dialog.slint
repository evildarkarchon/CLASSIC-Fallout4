import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "../components/fluent_button.slint";

// AboutDialog - Fluent-styled About dialog with application information
export component AboutDialog inherits Rectangle {
    // Properties
    in property<string> app-version: "8.0.0";
    in property<bool> show: false;

    // Callbacks
    callback close-clicked();
    callback open-github();
    callback open-nexus();

    // Only visible when show is true
    visible: root.show;

    // Full screen overlay
    width: 100%;
    height: 100%;

    // Semi-transparent backdrop
    background: #00000080;

    // Animate fade in/out
    animate opacity {
        duration: FluentDark.animation-normal;
        easing: ease-in-out;
    }

    states [
        visible when root.show: {
            opacity: 1;
        }
        hidden when !root.show: {
            opacity: 0;
        }
    ]

    // Focus scope for keyboard handling
    FocusScope {
        enabled: root.show;

        // Handle Escape key to close dialog
        key-pressed(event) => {
            if (event.text == "\u{001b}") {
                root.close-clicked();
                return accept;
            }
            return reject;
        }

        // Center the dialog
        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                alignment: center;

                // About dialog card
                Rectangle {
                background: FluentDark.layer2;
                border-radius: FluentDark.radius-lg;
                border-width: 1px;
                border-color: FluentDark.border;
                min-width: 500px;
                max-width: 600px;
                height: 450px;

                // Elevated shadow
                drop-shadow-blur: FluentDark.shadow-lg;
                drop-shadow-color: #00000060;
                drop-shadow-offset-y: 8px;

                // Animate scale in/out
                animate y {
                    duration: FluentDark.animation-normal;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1);
                }

                VerticalLayout {
                    padding: FluentDark.spacing-xl;
                    spacing: FluentDark.spacing-lg;

                    // App icon placeholder (you can replace with actual icon)
                    Rectangle {
                        width: 64px;
                        height: 64px;
                        border-radius: FluentDark.radius-md;
                        background: FluentDark.accent;

                        // CLASSIC logo text
                        Text {
                            text: "C";
                            color: FluentDark.text-on-accent;
                            font-size: 36px;
                            font-weight: FluentDark.font-weight-bold;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Application name
                    Text {
                        text: "CLASSIC";
                        color: FluentDark.text-primary;
                        font-size: FluentDark.font-size-2xl;
                        font-weight: FluentDark.font-weight-bold;
                        horizontal-alignment: center;
                    }

                    // Subtitle
                    Text {
                        text: "Crash Log Auto Scanner & Setup Integrity Checker";
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    // Version
                    Text {
                        text: "Version " + root.app-version;
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-semibold;
                        horizontal-alignment: center;
                    }

                    // Divider
                    Rectangle {
                        height: 1px;
                        background: FluentDark.border-subtle;
                    }

                    // Description
                    Text {
                        text: "A high-performance hybrid Python-Rust desktop application for analyzing crash logs from Bethesda games (Fallout 4 and Skyrim).";
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-base;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }

                    // Authors
                    Text {
                        text: "Developed by the CLASSIC Team";
                        color: FluentDark.text-secondary;
                        font-size: FluentDark.font-size-sm;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: center;
                    }

                    // Links section
                    HorizontalLayout {
                        spacing: FluentDark.spacing-sm;
                        alignment: center;

                        FluentButton {
                            text: "GitHub";
                            primary: false;
                            clicked => {
                                root.open-github();
                            }
                        }

                        FluentButton {
                            text: "Nexus Mods";
                            primary: false;
                            clicked => {
                                root.open-nexus();
                            }
                        }
                    }

                    // License
                    Text {
                        text: "Licensed under MIT License";
                        color: FluentDark.text-tertiary;
                        font-size: FluentDark.font-size-sm;
                        font-weight: FluentDark.font-weight-regular;
                        horizontal-alignment: center;
                    }

                    // Spacer to push close button to bottom
                    Rectangle {
                        background: transparent;
                    }

                    // Close button
                    HorizontalLayout {
                        alignment: center;

                        FluentButton {
                            text: "Close";
                            primary: true;
                            clicked => {
                                root.close-clicked();
                            }
                        }
                    }
                }
            }
        }  // End HorizontalLayout (center)
    }  // End VerticalLayout (center)

    // Handle click outside to close
    TouchArea {
            clicked => {
                root.close-clicked();
            }
        }
    }  // End FocusScope
}
