import { FluentDark } from "../styles/fluent_dark.slint";
import { FluentButton } from "../components/fluent_button.slint";
import { FluentCheckbox } from "../components/fluent_checkbox.slint";
import { ProgressSpinner } from "../components/progress_spinner.slint";

// UpdateDialog - Dialog for checking and notifying about application updates
export component UpdateDialog inherits Rectangle {
    // Properties
    in property<bool> show: false;
    in property<bool> checking: false;
    in property<bool> update-available: false;
    in property<string> current-version: "8.0.0";
    in property<string> latest-version: "";
    in property<string> release-notes: "";
    in property<string> error-message: "";
    in-out property<bool> dont-check-again: false;

    // Callbacks
    callback close-clicked();
    callback download-clicked();
    callback skip-clicked();

    // Only visible when show is true
    visible: root.show;

    // Full screen overlay
    width: 100%;
    height: 100%;

    // Semi-transparent backdrop
    background: #00000080;

    // Animate fade in/out
    animate opacity {
        duration: FluentDark.animation-normal;
        easing: ease-in-out;
    }

    states [
        visible when root.show: {
            opacity: 1;
        }
        hidden when !root.show: {
            opacity: 0;
        }
    ]

    // Focus scope for keyboard handling
    FocusScope {
        enabled: root.show && !root.checking;

        // Handle Escape key to close dialog (only when not checking)
        key-pressed(event) => {
            if (event.text == "\u{001b}" && !root.checking) {
                root.close-clicked();
                return accept;
            }
            return reject;
        }

        // Center the dialog
        VerticalLayout {
            alignment: center;

            HorizontalLayout {
                alignment: center;

                // Update dialog card
                Rectangle {
                background: FluentDark.layer2;
                border-radius: FluentDark.radius-lg;
                border-width: 1px;
                border-color: FluentDark.border;
                min-width: 500px;
                max-width: 600px;
                height: 400px;

                // Elevated shadow
                drop-shadow-blur: FluentDark.shadow-lg;
                drop-shadow-color: #00000060;
                drop-shadow-offset-y: 8px;

                // Animate scale in/out
                animate y {
                    duration: FluentDark.animation-normal;
                    easing: cubic-bezier(0.1, 0.9, 0.2, 1);
                }

                VerticalLayout {
                    padding: FluentDark.spacing-lg;
                    spacing: FluentDark.spacing-md;

                    // Title
                    Text {
                        text: root.checking ? "Checking for Updates..." :
                              (root.update-available ? "Update Available" :
                               (root.error-message != "" ? "Update Check Failed" : "No Updates Available"));
                        color: root.update-available ? FluentDark.success : FluentDark.text-primary;
                        font-size: FluentDark.font-size-xl;
                        font-weight: FluentDark.font-weight-semibold;
                        horizontal-alignment: center;
                    }

                    // Content area
                    if root.checking: VerticalLayout {
                        spacing: FluentDark.spacing-lg;
                        alignment: center;

                        ProgressSpinner {
                            active: root.checking;
                            size: 64px;
                        }

                        Text {
                            text: "Checking for updates from GitHub...";
                            color: FluentDark.text-secondary;
                            font-size: FluentDark.font-size-base;
                            horizontal-alignment: center;
                        }
                    }

                    if !root.checking && root.error-message != "": VerticalLayout {
                        spacing: FluentDark.spacing-md;

                        // Error icon
                        Rectangle {
                            width: 48px;
                            height: 48px;
                            border-radius: 24px;
                            background: FluentDark.error;

                            Text {
                                text: "✕";
                                color: #ffffff;
                                font-size: 24px;
                                font-weight: FluentDark.font-weight-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: root.error-message;
                            color: FluentDark.text-secondary;
                            font-size: FluentDark.font-size-base;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }
                    }

                    if !root.checking && root.error-message == "" && root.update-available: VerticalLayout {
                        spacing: FluentDark.spacing-md;

                        // Version comparison
                        HorizontalLayout {
                            spacing: FluentDark.spacing-md;
                            alignment: center;

                            VerticalLayout {
                                spacing: FluentDark.spacing-xs;

                                Text {
                                    text: "Current Version";
                                    color: FluentDark.text-tertiary;
                                    font-size: FluentDark.font-size-sm;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: root.current-version;
                                    color: FluentDark.text-primary;
                                    font-size: FluentDark.font-size-lg;
                                    font-weight: FluentDark.font-weight-semibold;
                                    horizontal-alignment: center;
                                }
                            }

                            Text {
                                text: "→";
                                color: FluentDark.accent;
                                font-size: FluentDark.font-size-xl;
                                vertical-alignment: center;
                            }

                            VerticalLayout {
                                spacing: FluentDark.spacing-xs;

                                Text {
                                    text: "Latest Version";
                                    color: FluentDark.text-tertiary;
                                    font-size: FluentDark.font-size-sm;
                                    horizontal-alignment: center;
                                }

                                Text {
                                    text: root.latest-version;
                                    color: FluentDark.success;
                                    font-size: FluentDark.font-size-lg;
                                    font-weight: FluentDark.font-weight-semibold;
                                    horizontal-alignment: center;
                                }
                            }
                        }

                        // Release notes
                        if root.release-notes != "": VerticalLayout {
                            spacing: FluentDark.spacing-xs;

                            Text {
                                text: "Release Notes:";
                                color: FluentDark.text-secondary;
                                font-size: FluentDark.font-size-sm;
                                font-weight: FluentDark.font-weight-semibold;
                            }

                            Flickable {
                                height: 120px;
                                width: 100%;
                                viewport-height: 240px;

                                Text {
                                    text: root.release-notes;
                                    color: FluentDark.text-secondary;
                                    font-size: FluentDark.font-size-sm;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    if !root.checking && root.error-message == "" && !root.update-available: VerticalLayout {
                        spacing: FluentDark.spacing-md;
                        alignment: center;

                        // Success icon
                        Rectangle {
                            width: 48px;
                            height: 48px;
                            border-radius: 24px;
                            background: FluentDark.success;

                            Text {
                                text: "✓";
                                color: #000000;
                                font-size: 24px;
                                font-weight: FluentDark.font-weight-bold;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: "You are using the latest version!";
                            color: FluentDark.text-secondary;
                            font-size: FluentDark.font-size-base;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: "Version " + root.current-version;
                            color: FluentDark.text-tertiary;
                            font-size: FluentDark.font-size-sm;
                            horizontal-alignment: center;
                        }
                    }

                    // Spacer
                    Rectangle {
                        background: transparent;
                    }

                    // Don't check again option
                    if !root.checking: FluentCheckbox {
                        text: "Don't check for updates automatically";
                        checked <=> root.dont-check-again;
                    }

                    // Button bar
                    if !root.checking: HorizontalLayout {
                        spacing: FluentDark.spacing-sm;
                        alignment: end;

                        if root.update-available: FluentButton {
                            text: "Skip";
                            primary: false;
                            clicked => {
                                root.skip-clicked();
                            }
                        }

                        if root.update-available: FluentButton {
                            text: "Download";
                            primary: true;
                            clicked => {
                                root.download-clicked();
                            }
                        }

                        if !root.update-available: FluentButton {
                            text: "Close";
                            primary: true;
                            clicked => {
                                root.close-clicked();
                            }
                        }
                    }
                }
            }
        }  // End HorizontalLayout (center)
    }  // End VerticalLayout (center)

    // Handle click outside to close (only when not checking)
    if !root.checking: TouchArea {
            clicked => {
                root.close-clicked();
            }
        }
    }  // End FocusScope
}
