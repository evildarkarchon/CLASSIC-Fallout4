// Fluent Design Dark Theme for CLASSIC
// Based on Windows 11 Fluent Design System
// https://fluent2.microsoft.design/

export global FluentDark {
    // ========================================
    // BASE LAYERS
    // ========================================
    // Windows 11 dark theme base colors with layered elevation
    out property<color> background: #202020;        // Solid background
    out property<color> layer1: #2b2b2b;            // Elevated layer 1
    out property<color> layer2: #323232;            // Elevated layer 2
    out property<color> layer3: #3a3a3a;            // Elevated layer 3 (cards/buttons)

    // Acrylic/transparency for modern effects
    out property<color> acrylic-background: #202020cc;  // 80% opacity
    out property<color> acrylic-border: #5c5c5c80;      // 50% opacity

    // ========================================
    // TEXT HIERARCHY (WCAG AA Compliant)
    // ========================================
    out property<color> text-primary: #ffffff;      // Primary text (contrast ratio: 15.09:1)
    out property<color> text-secondary: #a0a0a0;    // Secondary text (contrast ratio: 5.85:1)
    out property<color> text-tertiary: #6d6d6d;     // Disabled/tertiary text (contrast ratio: 3.39:1)
    out property<color> text-on-accent: #000000;    // Text on accent backgrounds (contrast ratio: 9.74:1)

    // ========================================
    // INTERACTIVE STATES
    // ========================================
    out property<color> hover: #404040;             // Hover overlay
    out property<color> pressed: #2a2a2a;           // Pressed overlay
    out property<color> disabled: #3a3a3a;          // Disabled background
    out property<color> disabled-text: #6d6d6d;    // Disabled text

    // ========================================
    // ACCENT COLORS (Fluent Blue)
    // ========================================
    out property<color> accent: #60cdff;            // Primary accent (Fluent blue)
    out property<color> accent-hover: #4fb3e6;      // Darker blue on hover
    out property<color> accent-pressed: #3e9ccf;    // Even darker when pressed
    out property<color> accent-secondary: #005fb8;  // Secondary accent

    // ========================================
    // SEMANTIC COLORS
    // ========================================
    out property<color> success: #2ded8a;           // Green - success/papyrus start
    out property<color> warning: #faa919;           // Orange - warnings
    out property<color> error: #ed2d2d;             // Red - errors/papyrus stop
    out property<color> info: #60cdff;              // Blue - informational

    // ========================================
    // BORDERS AND DIVIDERS
    // ========================================
    out property<color> border: #5c5c5c;            // Default borders
    out property<color> border-subtle: #383838;     // Subtle dividers
    out property<color> focus-border: #60cdff;      // Focus indicator (accent)

    // ========================================
    // SCROLLBARS
    // ========================================
    out property<color> scrollbar-bg: #1a1a1a;          // Scrollbar track
    out property<color> scrollbar-thumb: #5c5c5c;       // Scrollbar thumb
    out property<color> scrollbar-thumb-hover: #707070; // Scrollbar thumb hover

    // ========================================
    // SPACING SYSTEM (8px base unit - Fluent standard)
    // ========================================
    out property<length> spacing-xs: 4px;           // Tight spacing
    out property<length> spacing-sm: 8px;           // Default spacing
    out property<length> spacing-md: 16px;          // Section spacing
    out property<length> spacing-lg: 24px;          // Major section breaks
    out property<length> spacing-xl: 32px;          // Page margins

    // ========================================
    // BORDER RADIUS (Fluent uses 4px base)
    // ========================================
    out property<length> radius-sm: 4px;            // Small radius (buttons)
    out property<length> radius-md: 8px;            // Medium radius (cards)
    out property<length> radius-lg: 12px;           // Large radius (modals)

    // ========================================
    // TYPOGRAPHY (Segoe UI family - Windows standard)
    // ========================================
    out property<string> font-family: "Segoe UI Variable";
    out property<string> font-family-fallback: "Segoe UI";
    out property<string> font-family-mono: "Cascadia Mono";

    // Font sizes
    out property<length> font-size-sm: 12px;        // Small text
    out property<length> font-size-base: 14px;      // Body text
    out property<length> font-size-lg: 16px;        // Large body text
    out property<length> font-size-xl: 20px;        // Headings
    out property<length> font-size-2xl: 24px;       // Large headings

    // Font weights
    out property<int> font-weight-regular: 400;
    out property<int> font-weight-semibold: 600;
    out property<int> font-weight-bold: 700;

    // ========================================
    // SHADOWS (Subtle depth)
    // ========================================
    out property<length> shadow-sm: 2px;            // Small shadow
    out property<length> shadow-md: 4px;            // Medium shadow
    out property<length> shadow-lg: 8px;            // Large shadow
    out property<color> shadow-color: #00000040;    // Shadow color (25% opacity)

    // ========================================
    // ANIMATION DURATIONS (Fluent standard)
    // ========================================
    out property<duration> animation-fast: 150ms;   // Fast animations
    out property<duration> animation-normal: 250ms; // Normal animations
    out property<duration> animation-slow: 350ms;   // Slow animations

    // ========================================
    // COMPONENT-SPECIFIC SIZES
    // ========================================
    out property<length> button-height: 32px;       // Standard button height
    out property<length> button-min-width: 120px;   // Minimum button width
    out property<length> input-height: 32px;        // Input field height
    out property<length> tab-height: 48px;          // Tab bar height

    // ========================================
    // SPECIAL COLORS (CLASSIC-specific)
    // ========================================
    out property<color> papyrus-start: #2ded8a;     // Green for Papyrus START
    out property<color> papyrus-stop: #ed2d2d;      // Red for Papyrus STOP
}

// Typography helpers
export global Typography {
    // Headings
    out property<length> h1: 24px;          // weight: 700
    out property<length> h2: 20px;          // weight: 600
    out property<length> h3: 16px;          // weight: 600

    // Body text
    out property<length> body: 14px;        // weight: 400 (default)
    out property<length> body-large: 16px;  // weight: 400
    out property<length> body-small: 12px;  // weight: 400

    // UI elements
    out property<length> button: 14px;      // weight: 600
    out property<length> caption: 12px;     // weight: 400
    out property<length> label: 14px;       // weight: 600
}