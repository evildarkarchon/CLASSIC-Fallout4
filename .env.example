# CLASSIC environment variables — copy to .env and fill in your values.
# .env is gitignored; .env.example is tracked.

# GitHub personal access token (used by update-check and release scripts)
GITHUB_TOKEN=

# X.500 subject for the self-signed code-signing certificate.
# Format: CN=Your Name, E=you@example.com, O=Your Org
# If unset, the signing script will skip certificate generation.
CLASSIC_SIGNING_SUBJECT=
