# Include CLASSIC Data files for bundled distribution
recursive-include "CLASSIC Data" *.yaml *.yml *.db *.txt
recursive-include "CLASSIC Data/databases" *
include "CLASSIC Data/CLASSIC Settings.yaml"

# Include package data
include README.md
include LICENSE
include pyproject.toml

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.log
prune tests
prune docs
prune Release
