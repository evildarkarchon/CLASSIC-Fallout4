{
  "contractVersion": "1.0.0",
  "phase": "phase1",
  "description": "Hybrid-tiered Node vs Rust parity contract for high-level APIs.",
  "tierDefinitions": {
    "tier1": "Must-have high-level APIs required by app workflows and cross-language integration.",
    "tier2": "Lower-level or advanced APIs intentionally triaged for later parity work."
  },
  "ownerModules": {
    "scanlog": {
      "description": "Crash log orchestration, parsing, and crash analysis APIs."
    },
    "config": {
      "description": "YAML data and runtime configuration APIs."
    },
    "version_registry": {
      "description": "Game version lookup and compatibility APIs."
    },
    "aux": {
      "description": "Non-phase1 exports outside scanlog/config/version-registry."
    }
  },
  "squads": {
    "scanlog_config": {
      "name": "Squad A (scanlog/config)",
      "ownerModules": [
        "scanlog",
        "config"
      ]
    },
    "version_registry_aux": {
      "name": "Squad B (version-registry/aux)",
      "ownerModules": [
        "version_registry",
        "aux"
      ]
    }
  },
